---
// Frontmatter
const { frontmatter } = Astro.props;

// Retrieve all posts from the "posts" collection, which returns an unsorted array of post objects
import { getCollection } from 'astro:content';

const allPostsUnsorted = await getCollection('posts');
// Sort the posts in descending order by publication date (newest to oldest)
const allPosts = allPostsUnsorted.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

import { Image } from 'astro:assets';
import BlogCard from '@/components/blog/BlogCard.astro';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import JsonLd from '@/components/fundations/head/JsonLd.astro';
import { APP_CONFIG } from '@/lib/constants';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const postUrl = `${APP_CONFIG.BASE_URL}/blog/posts/${Astro.params.slug}/`;
// `frontmatter.image.url` is an `ImageMetadata` object (resolved by the
// content collection's `image()` helper). Its `.src` is the public URL.
const rawImage = frontmatter.image?.url;
const postImage = (() => {
  if (!rawImage) return `${APP_CONFIG.BASE_URL}/og-image.jpg`;
  const src = typeof rawImage === 'string' ? rawImage : (rawImage as { src?: string }).src;
  if (!src) return `${APP_CONFIG.BASE_URL}/og-image.jpg`;
  return src.startsWith('http') ? src : `${APP_CONFIG.BASE_URL}${src}`;
})();
const datePublished = new Date(frontmatter.pubDate).toISOString();
---

<BaseLayout
  seoProps={{
    title: frontmatter.title,
    description: frontmatter.description,
    image: frontmatter.image?.url,
    url: `/blog/posts/${Astro.params.slug}/`,
  }}
>
  <!-- Article JSON-LD for AI/SEO citability -->
  <JsonLd
    data={{
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: frontmatter.title,
      description: frontmatter.description,
      image: postImage,
      datePublished,
      dateModified: frontmatter.lastmod
        ? new Date(frontmatter.lastmod).toISOString()
        : datePublished,
      author: {
        '@type': 'Organization',
        name: 'Kukode',
        url: APP_CONFIG.BASE_URL,
      },
      publisher: {
        '@type': 'Organization',
        name: 'Kukode',
        logo: {
          '@type': 'ImageObject',
          url: `${APP_CONFIG.BASE_URL}/icon.svg`,
        },
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': postUrl,
      },
      keywords: frontmatter.tags?.join(', '),
      inLanguage: lang,
    }}
  />
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="text-balance">
        <div class="text-center max-w-3xl mx-auto text-balance">
          <Text
            tag="h1"
            variant="displayLG"
            class="text-base-900 font-display font-thin"
          >
            {frontmatter.title}
          </Text>
          <Text tag="p" variant="textBase" class="text-base-600 mt-4">
            {frontmatter.description}
          </Text>
        </div>
        <div class="flex flex-wrap items-center gap-1 mt-8 justify-center">
          {
            frontmatter.tags.map((tag) => (
              <>
                <Button
                  isLink
                  title={tag}
                  size="sm"
                  variant="muted"
                  aria-label={tag}
                  href={`/blog/tags/${tag}`}
                  class="text-accent-500  font-medium text-xs hover:text-base-900   capitalize  "
                >
                  {tag}
                </Button>
              </>
            ))
          }
        </div>
      </div>
      <div class="p-8 bg-base-50 rounded-lg mt-12">
        <Image
          width={1400}
          height={1400}
          loading="lazy"
          decoding="async"
          src={frontmatter.image.url}
          alt={frontmatter.image.alt}
          class="size-full aspect-8/5 object-top rounded shadow object-cover"
        />
      </div>
      <Wrapper variant="narrow" class="mt-12"
        ><Wrapper variant="prose"><slot /></Wrapper></Wrapper
      >
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-12">
      <div class="flex flex-wrap gap-4 justify-between items-center">
        <Text
          tag="h2"
          variant="displaySM"
          class="text-base-900 font-display font-thin">{t('blog.latestPosts')}</Text
        >
        <Button isLink size="sm" variant="muted" href="/blog/">
          {t('blog.seeAllPosts')}
        </Button>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 mt-8">
        {allPosts.slice(0, 3).map((post) => <BlogCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
