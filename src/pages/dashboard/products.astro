---
import { Effect } from 'effect';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import EmptyState from '@/components/global/EmptyState.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { ISiteRepository } from '@/domain/site';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const user = (Astro.locals as any).user;
if (!user) {
  return Astro.redirect('/signin');
}

const appRuntime = createAppRuntime(Astro.locals);
const mySites = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* ISiteRepository;
  return yield* repo.getCreatorSites(user.id);
}));
---

<DashboardLayout title={lang === 'en' ? 'My Products' : 'Produk Saya'}>
  <div class="mb-6 flex justify-between items-center">
    <Text tag="p" variant="textSM" class="text-base-600">
      {lang === 'en' ? 'Manage your submissions and track their performance.' : 'Kelola kiriman produk Anda dan pantau performanya.'}
    </Text>
    <Button size="xs" variant="accent" href="/submit">
      {lang === 'en' ? 'Submit New Product' : 'Kirim Produk Baru'}
    </Button>
  </div>

  {(!mySites || mySites.length === 0) ? (
    <EmptyState
      title={t('dashboard.emptyTitle')}
      description={t('dashboard.emptyDesc')}
      icon="ri-rocket-line"
      actionText={t('dashboard.emptyAction')}
      actionHref="/submit"
    />
  ) : (
    <div class="space-y-6">
      {mySites.map((site: any) => (
        <div class="rounded-xl border border-base-200 bg-white p-5 flex flex-col sm:flex-row gap-5 shadow-sm hover:shadow-md transition-shadow duration-200">
          {site.thumbnail_url && (
            <div class="w-full sm:w-44 h-28 rounded-lg overflow-hidden border border-base-100 shrink-0 bg-base-50">
              <img
                src={site.thumbnail_url}
                alt={site.title}
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </div>
          )}
          
          <div class="flex-1 min-w-0 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2.5 flex-wrap">
                <Text tag="h3" variant="textBase" class="text-base-900 font-semibold truncate">
                  {site.title}
                </Text>
                
                {/* Status Badges */}
                {site.status === 'approved' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700 border border-green-200">
                    Approved
                  </span>
                )}
                {site.status === 'pending_review' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-50 text-yellow-700 border border-yellow-200">
                    Pending Review
                  </span>
                )}
                {site.status === 'rejected' && (
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-50 text-red-700 border border-red-200">
                    Rejected
                  </span>
                )}
              </div>
              
              <Text tag="p" variant="textSM" class="text-base-500 mt-1 line-clamp-2">
                {site.tagline}
              </Text>
              
              <div class="flex items-center gap-3.5 mt-2.5 flex-wrap text-xs text-base-400">
                <a
                  href={site.live_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent-600 hover:underline flex items-center gap-1 font-medium"
                >
                  <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  {site.live_url}
                </a>
                <span>•</span>
                <span>
                  {lang === 'en' ? 'Submitted on ' : 'Dikirim pada '}
                  {new Date(site.created_at).toLocaleDateString('id-ID', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                  })}
                </span>
              </div>
              
              {/* Tags */}
              {site.tags && site.tags.length > 0 && (
                <div class="flex gap-1.5 mt-3 flex-wrap">
                  {site.tags.map((tag: string) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold bg-base-50 border border-base-100 text-base-600 capitalize">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>

            {/* Rejection Reason Block */}
            {site.status === 'rejected' && site.rejection_reason && (
              <div class="mt-3.5 p-3 rounded-lg bg-red-50 border border-red-100 text-red-700 text-xs leading-relaxed">
                <span class="font-bold block mb-0.5">
                  {lang === 'en' ? 'Rejection Reason:' : 'Alasan Penolakan:'}
                </span>
                {site.rejection_reason}
              </div>
            )}
          </div>
          
          {/* Actions Column */}
          <div class="flex sm:flex-col items-stretch sm:justify-center gap-2 shrink-0 border-t sm:border-t-0 sm:border-l border-base-100 pt-4 sm:pt-0 sm:pl-5">
            {site.status === 'approved' ? (
              <>
                <Button
                  isLink
                  size="xs"
                  variant="muted"
                  href={`/sites/site/${site.id}`}
                  class="text-center w-full justify-center"
                >
                  {lang === 'en' ? 'View Page' : 'Lihat Halaman'}
                </Button>
                <Button
                  isLink
                  size="xs"
                  variant="default"
                  href={`/dashboard/analytics/${site.id}`}
                  class="text-center w-full justify-center"
                >
                  {lang === 'en' ? 'Analytics' : 'Analitik'}
                </Button>
              </>
            ) : (
              <span class="text-xs text-base-400 italic text-center w-full block py-2">
                {site.status === 'pending_review' 
                  ? (lang === 'en' ? 'Awaiting Approval' : 'Menunggu Persetujuan')
                  : (lang === 'en' ? 'Submission Rejected' : 'Pengiriman Ditolak')
                }
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>
