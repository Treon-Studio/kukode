---
// Retrieve all posts from the "sites" collection
import { getCollection } from 'astro:content';

const alltools = await getCollection('sites');
// Frontmatter
const { frontmatter, isDynamic = false, voteCount = 0, voted = false, siteId = '' } = Astro.props;

import { Image } from 'astro:assets';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import ArrowupRight from '@/components/fundations/icons/ArrowUpRight.astro';
import Comments from '@/components/sites/Comments.astro';
import SiteCard from '@/components/sites/SiteCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const seoProps = {
  title: frontmatter.title,
  description: frontmatter.description,
  image: frontmatter.thumbnail?.url,
  url: Astro.url.href,
};
---

<BaseLayout showSearch={true} seoProps={seoProps}>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-wrap justify-between gap-4">
        <div class="max-w-xl text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="text-base-900 font-display font-thin capitalize"
          >
            {frontmatter.title}
          </Text>
          <Text tag="p" variant="textSM" class="text-base-600 mt-4">
            {frontmatter.description}
          </Text>
        </div>
        <div class="flex items-center gap-2">
          {isDynamic && (
            <button
              type="button"
              class:list={[
                'flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 h-9 shadow-sm border focus:outline-none focus:ring-2 focus:ring-accent-500 cursor-pointer',
                voted
                  ? 'border-accent-300 bg-accent-50 text-accent-700'
                  : 'border-base-200 bg-white text-base-800 hover:border-accent-300 hover:bg-accent-50 hover:text-accent-700',
              ]}
              data-vote-btn
              data-site-id={siteId}
              data-voted={voted ? 'true' : 'false'}
            >
              <svg class="size-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M8 12V4M8 4L4 8M8 4L12 8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span data-vote-count={siteId}>{voteCount}</span>
            </button>
          )}
          <Button
            iconOnly
            size="xs"
            variant="default"
            href={frontmatter.live}
            title={frontmatter.title}
            target="_blank"
            data-visit-btn={siteId}
          >
            <ArrowupRight slot="icon" class="size-4" />
          </Button>
        </div>
      </div>
      <div class="p-8 bg-base-50 rounded-lg mt-12 relative group">
        {isDynamic ? (
          <img
            src={frontmatter.thumbnail.url}
            alt={frontmatter.thumbnail.alt || frontmatter.title}
            class="size-full aspect-8/5 object-top rounded shadow"
          />
        ) : (
          <Image
            width={1400}
            height={1400}
            loading="lazy"
            decoding="async"
            src={frontmatter.thumbnail.url}
            alt={frontmatter.thumbnail.alt}
            class="size-full aspect-8/5 object-top rounded shadow"
          />
        )}
      </div>
      <dl class="mt-4 divide-y divide-base-100 mb-12">
        {
          frontmatter.details?.map((details: any) => (
            <div class="flex itmes-center gap-2 justify-between py-2">
              <dt>
                <Text
                  tag="h3"
                  variant="textSM"
                  class="text-base-900 font-medium"
                >
                  {details.label}
                </Text>
              </dt>
              <dd>
                <Text tag="p" variant="textSM" class="text-base-600">
                  {details.value}
                </Text>
              </dd>
            </div>
          ))
        }
      </dl>

      {/* Content Slot for Markdown, or fallback description for Dynamic */}
      <div class="prose prose-base text-base-600 mb-12">
        <slot />
        {isDynamic && !Astro.slots.has('default') && (
          <p>{frontmatter.description}</p>
        )}
      </div>

      {/* Comments Section */}
      <hr class="border-base-100 my-12" />
      <Comments siteId={frontmatter.id} />
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-wrap gap-4 justify-between items-center">
        <Text
          tag="h2"
          variant="displaySM"
          class="text-base-900 font-display font-thin">Latest additions</Text
        >
        <Button isLink size="sm" variant="muted" href="/sites/">
          See all tools
        </Button>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 mt-8">
        {alltools.slice(0, 4).map((post) => <SiteCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<script is:inline>
  if (!window.__kukodeVoteInit) {
    window.__kukodeVoteInit = true;
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('[data-vote-btn]');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      const siteId = btn.dataset.siteId;
      if (!siteId) return;

      const countEl = btn.querySelector('[data-vote-count]');
      const wasVoted = btn.dataset.voted === 'true';
      const currentCount = parseInt(countEl?.textContent || '0', 10);

      // Optimistic update
      btn.dataset.voted = wasVoted ? 'false' : 'true';
      if (countEl) countEl.textContent = wasVoted ? currentCount - 1 : currentCount + 1;

      if (wasVoted) {
        btn.classList.remove('border-accent-300', 'bg-accent-50', 'text-accent-700');
        btn.classList.add('border-base-200', 'bg-white', 'text-base-800');
      } else {
        btn.classList.add('border-accent-300', 'bg-accent-50', 'text-accent-700');
        btn.classList.remove('border-base-200', 'bg-white', 'text-base-800');
      }

      try {
        const res = await fetch('/api/sites/vote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ site_id: siteId }),
        });

        const data = await res.json();

        if (res.status === 401) {
          btn.dataset.voted = wasVoted ? 'true' : 'false';
          if (countEl) countEl.textContent = currentCount;
          window.location.href = '/signin?redirect=' + encodeURIComponent(window.location.pathname);
          return;
        }

        if (!res.ok) {
          throw new Error(data.error || 'Vote failed');
        }

        btn.dataset.voted = data.voted ? 'true' : 'false';
        if (countEl) countEl.textContent = data.vote_count;
      } catch (err) {
        btn.dataset.voted = wasVoted ? 'true' : 'false';
        if (countEl) countEl.textContent = currentCount;
      }
    });
  }

  // Click tracking
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-visit-btn]');
    if (!btn) return;

    const siteId = btn.dataset.visitBtn;
    if (!siteId) return;

    fetch('/api/events/track', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        site_id: siteId,
        event_type: 'click',
        referrer: window.location.href,
      }),
    }).catch(() => {});
  });
</script>
