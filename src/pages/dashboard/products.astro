---
import { Effect } from 'effect';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import EmptyState from '@/components/global/EmptyState.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { ISiteRepository } from '@/domain/site';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const user = (Astro.locals as any).user;
if (!user) {
  return Astro.redirect('/signin');
}

const appRuntime = createAppRuntime(Astro.locals);
const mySitesAll = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* ISiteRepository;
  return yield* repo.getCreatorSites(user.id);
}));

// Filter by ?status= query param
const statusFilter = Astro.url.searchParams.get('status') || 'all';
const mySites = statusFilter === 'all'
  ? mySitesAll
  : mySitesAll.filter((s: any) => s.status === statusFilter);
const statusCounts = {
  all: mySitesAll.length,
  approved: mySitesAll.filter((s: any) => s.status === 'approved').length,
  pending_review: mySitesAll.filter((s: any) => s.status === 'pending_review').length,
  rejected: mySitesAll.filter((s: any) => s.status === 'rejected').length,
};
---

<DashboardLayout title={t('dashboard.myProducts')}>
  <div class="mb-6 flex justify-between items-center">
    <Text tag="p" variant="textSM" class="text-base-600">
      {t('dashboard.manageSubmissions')}
    </Text>
    <Button size="xs" variant="accent" href="/submit">
      {t('dashboard.submitNewProduct')}
    </Button>
  </div>

  <!-- Status Filter Pills -->
  <div class="inline-flex items-center gap-1.5 bg-base-50 p-1.5 rounded-xl border border-base-200 mb-6">
    {[['all', 'All'], ['approved', 'Disetujui'], ['pending_review', 'Pending Review'], ['rejected', 'Ditolak']].map(([key, label]) => (
      <a
        href={key === 'all' ? '/dashboard/products' : `/dashboard/products?status=${key}`}
        class:list={[
          'px-4 py-2 text-xs font-semibold rounded-lg transition-all duration-200',
          statusFilter === key
            ? 'bg-white text-base-900 shadow-sm border border-base-200/50'
            : 'text-base-500 hover:text-base-900',
        ]}
      >
        {label} ({statusCounts[key as keyof typeof statusCounts]})
      </a>
    ))}
  </div>

  {(!mySites || mySites.length === 0) ? (
    <EmptyState
      title={t('dashboard.emptyTitle')}
      description={t('dashboard.emptyDesc')}
      icon="ri-rocket-line"
      actionText={t('dashboard.emptyAction')}
      actionHref="/submit"
    />
  ) : (
    <div class="space-y-6">
      {mySites.map((site: any) => (
        <div class="rounded-xl border border-base-200 bg-white p-5 flex flex-col sm:flex-row gap-5 shadow-sm hover:shadow-md transition-shadow duration-200">
          {site.thumbnail_url && (
            <div class="w-full sm:w-44 h-28 rounded-lg overflow-hidden border border-base-100 shrink-0 bg-base-50">
              <img
                src={site.thumbnail_url}
                alt={site.title}
                class="w-full h-full object-cover object-top"
                loading="lazy"
              />
            </div>
          )}
          
          <div class="flex-1 min-w-0 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-2.5 flex-wrap">
                <Text tag="h3" variant="textBase" class="text-base-900 font-semibold truncate">
                  {site.title}
                </Text>
                
                {/* Status Badges */}
                {site.status === 'approved' && (
                  <a href="/dashboard/products?status=approved" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-50 text-green-700 border border-green-200 hover:bg-green-100 hover:ring-1 hover:ring-green-300 transition-all cursor-pointer">
                    {t('dashboard.approved')}
                  </a>
                )}
                {site.status === 'pending_review' && (
                  <a href="/dashboard/products?status=pending_review" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-50 text-yellow-700 border border-yellow-200 hover:bg-yellow-100 hover:ring-1 hover:ring-yellow-300 transition-all cursor-pointer">
                    {t('dashboard.pendingReview')}
                  </a>
                )}
                {site.status === 'rejected' && (
                  <a href="/dashboard/products?status=rejected" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-red-50 text-red-700 border border-red-200 hover:bg-red-100 hover:ring-1 hover:ring-red-300 transition-all cursor-pointer">
                    {t('dashboard.rejected')}
                  </a>
                )}
              </div>
              
              <Text tag="p" variant="textSM" class="text-base-500 mt-1 line-clamp-2">
                {site.tagline}
              </Text>
              
              <div class="flex items-center gap-3.5 mt-2.5 flex-wrap text-xs text-base-400">
                <a
                  href={site.live_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent-600 hover:underline flex items-center gap-1 font-medium"
                >
                  <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                  {site.live_url}
                </a>
                <span>•</span>
                <span>
                  {t('dashboard.submittedOn')}
                  {new Date(site.created_at).toLocaleDateString('id-ID', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                  })}
                </span>
              </div>
              
              {/* Tags */}
              {site.tags && site.tags.length > 0 && (
                <div class="flex gap-1.5 mt-3 flex-wrap">
                  {site.tags.map((tag: string) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-semibold bg-base-50 border border-base-100 text-base-600 capitalize">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>

            {/* Rejection Reason Block */}
            {site.status === 'rejected' && site.rejection_reason && (
              <div class="mt-3.5 p-3 rounded-lg bg-red-50 border border-red-100 text-red-700 text-xs leading-relaxed">
                <span class="font-bold block mb-0.5">
                  {t('dashboard.rejectionReason')}
                </span>
                {site.rejection_reason}
              </div>
            )}
          </div>
          
          {/* Actions Column */}
          <div class="flex sm:flex-col items-stretch sm:justify-center gap-2 shrink-0 border-t sm:border-t-0 sm:border-l border-base-100 pt-4 sm:pt-0 sm:pl-5">
            {site.status === 'approved' ? (
              <>
                <Button
                  isLink
                  size="xs"
                  variant="muted"
                  href={`/sites/site/${site.id}`}
                  class="text-center w-full justify-center"
                >
                  {t('dashboard.viewPage')}
                </Button>
                <Button
                  isLink
                  size="xs"
                  variant="default"
                  href={`/dashboard/analytics/${site.id}`}
                  class="text-center w-full justify-center"
                >
                  {t('dashboard.analytics')}
                </Button>
              </>
            ) : (
              <span class="text-xs text-base-400 italic text-center w-full block py-2">
                {site.status === 'pending_review'
                  ? t('dashboard.awaitingApproval')
                  : t('dashboard.submissionRejected')}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</DashboardLayout>
