---
import { desc, eq } from 'drizzle-orm';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import ArrowupRight from '@/components/fundations/icons/ArrowUpRight.astro';
import { db } from '@/db';
import { potdHistory, profiles, submittedSites, votes } from '@/db/schema';

const user = (Astro.locals as any).user;

// Fetch latest POTD entry
const [latestPOTD] = await db.select().from(potdHistory).orderBy(desc(potdHistory.date)).limit(1);

let site: any = null;
let voteCount = 0;
let voted = false;

if (latestPOTD) {
  const [dbSite] = await db
    .select({
      id: submittedSites.id,
      title: submittedSites.title,
      tagline: submittedSites.tagline,
      description: submittedSites.description,
      live_url: submittedSites.live_url,
      thumbnail_url: submittedSites.thumbnail_url,
      maker_username: profiles.username,
    })
    .from(submittedSites)
    .leftJoin(profiles, eq(submittedSites.maker_id, profiles.id))
    .where(eq(submittedSites.id, latestPOTD.site_id))
    .limit(1);

  if (dbSite) {
    const siteVotes = await db.select().from(votes).where(eq(votes.site_id, dbSite.id));
    voteCount = siteVotes.length;
    voted = user ? siteVotes.some((v) => v.user_id === user.id) : false;
    site = dbSite;
  }
}
---

{site && (
  <section class="relative overflow-hidden py-10 px-6 sm:px-8 bg-gradient-to-br from-accent-50/70 via-white to-base-50/50 border border-accent-100 rounded-3xl shadow-sm max-w-5xl mx-auto mb-16 group">
    {/* Background Decorative Blur */}
    <div class="absolute -top-24 -right-24 size-96 bg-accent-200/40 rounded-full blur-3xl -z-10 group-hover:bg-accent-200/50 transition-colors duration-500"></div>
    <div class="absolute -bottom-24 -left-24 size-96 bg-base-100/50 rounded-full blur-3xl -z-10"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      {/* Product Information */}
      <div class="lg:col-span-7 space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold bg-accent-100 text-accent-700 border border-accent-200">
          <svg class="size-4 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          PRODUCT OF THE DAY
        </div>

        <div class="space-y-2">
          <Text tag="h2" variant="displaySM" class="text-base-900 font-display font-semibold tracking-tight">
            {site.title}
          </Text>
          <Text tag="p" variant="textLG" class="text-base-800 font-medium font-sans">
            {site.tagline}
          </Text>
        </div>

        <Text tag="p" variant="textSM" class="text-base-600 leading-relaxed font-sans max-w-xl">
          {site.description || 'No description provided.'}
        </Text>

        <div class="flex items-center gap-3 text-xs text-base-500 flex-wrap">
          {site.maker_username && (
            <span>
              by <strong class="text-base-800">@{site.maker_username}</strong>
            </span>
          )}
          <span>•</span>
          <span>
            Featured on {latestPOTD.date ? new Date(latestPOTD.date).toLocaleDateString('id-ID', {
              day: 'numeric',
              month: 'long',
              year: 'numeric'
            }) : 'Today'}
          </span>
        </div>

        <div class="flex items-center gap-3.5 pt-3">
          {/* Large Interactive Upvote Button */}
          <button
            type="button"
            class:list={[
              'flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shadow-sm border focus:outline-none focus:ring-2 focus:ring-accent-500 cursor-pointer',
              voted
                ? 'border-accent-300 bg-accent-50 text-accent-700'
                : 'border-base-200 bg-white text-base-800 hover:border-accent-300 hover:bg-accent-50 hover:text-accent-700',
            ]}
            data-vote-btn
            data-site-id={site.id}
            data-voted={voted ? 'true' : 'false'}
          >
            <svg class="size-4.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M8 12V4M8 4L4 8M8 4L12 8" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            <span>Upvote</span>
            <span class="border-l border-base-200/80 pl-2 ml-1" data-vote-count={site.id}>{voteCount}</span>
          </button>

          <Button
            isLink
            size="sm"
            variant="muted"
            href={`/sites/site/${site.id}`}
          >
            Details
          </Button>

          <Button
            iconOnly
            size="xs"
            variant="default"
            href={site.live_url}
            title={site.title}
            target="_blank"
            class="h-10 w-10 flex items-center justify-center border-base-200"
          >
            <ArrowupRight slot="icon" class="size-4" />
          </Button>
        </div>
      </div>

      {/* Product Image */}
      {site.thumbnail_url && (
        <div class="lg:col-span-5 relative h-52 sm:h-64 lg:h-72 w-full rounded-2xl overflow-hidden shadow-lg border border-accent-100/50 bg-base-50 shrink-0 group-hover:scale-[1.01] transition-transform duration-300">
          <img
            src={site.thumbnail_url}
            alt={site.title}
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
          <a href={`/sites/site/${site.id}`} class="absolute inset-0"></a>
        </div>
      )}
    </div>
  </section>
)}
