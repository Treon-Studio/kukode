---
import { AstroSeo } from "@lexingtonthemes/seo";
---

<AstroSeo
  title="Kukode"
  description="Kukode - Platform pengembangan web modern"
  canonical="https://kukode.treonstudio.com/current-page"
  openGraph={{
    url: "https://kukode.treonstudio.com/current-page",
    title: "Kukode",
    description: "Kukode - Platform pengembangan web modern",
    images: [
      {
        url: "https://kukode.treonstudio.com/og-image.jpg",
        width: 1200,
        height: 630,
        alt: "Kukode",
        type: "image/jpeg",
      },
    ],
    site_name: "Kukode",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@kukode",
    site: "@kukode",
    cardType: "summary_large_image",
  }}
/>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://kukode.treonstudio.com/" />
<meta property="og:title" content="Kukode" />
<meta
  property="og:description"
  content="Kukode - Platform pengembangan web modern"
/>
<meta
  property="og:image"
  content="https://kukode.treonstudio.com/path/to/image.jpg"
/>

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="https://kukode.treonstudio.com/" />
<meta property="twitter:title" content="Kukode" />
<meta
  property="twitter:description"
  content="Kukode - Platform pengembangan web modern"
/>
<meta
  property="twitter:image"
  content="https://kukode.treonstudio.com/path/to/image.jpg"
/>

<!-- Canonical URL -->
<link rel="canonical" href="https://kukode.treonstudio.com/" />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />
