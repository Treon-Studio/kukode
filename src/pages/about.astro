---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Text from '@/components/fundations/elements/Text.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<BaseLayout
  seoProps={{
    title: t('about.title'),
    description: t('about.desc'),
    url: '/about/',
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <Wrapper variant="narrow">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 font-display font-thin"
        >
          {t('about.title')}
        </Text>

        <!-- Direct answer (134–167 words). First 60 words answer the H1 verbatim. -->
        <div class="mt-10 text-lg leading-relaxed text-base-800">
          <p>{t('about.p1')}</p>
        </div>

        <Wrapper variant="prose" class="mt-10">
          <p>{t('about.p2')}</p>
          <p>{t('about.p3')}</p>
        </Wrapper>

        <div class="mt-12 border-t border-base-200 pt-6">
          <Text class="text-base-500 text-sm">— {t('about.author')}</Text>
        </div>
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>