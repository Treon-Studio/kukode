---
// Retrieve all posts from the "store" collection
import { getCollection } from 'astro:content';

const allstore = await getCollection('store');
// Frontmatter
const { frontmatter } = Astro.props;

import { Image } from 'astro:assets';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import Checkout from '@/components/fundations/icons/Checkout.astro';
import StoreCard from '@/components/store/StoreCard.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<BaseLayout
  seoProps={{
    title: frontmatter.title,
    description: frontmatter.description,
    image: frontmatter.image?.url,
    url: `/store/${Astro.params.slug}/`,
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      {Astro.url.searchParams.get('payment') === 'success' && (
        <div class="mb-8 p-4 rounded-xl bg-green-50 border border-green-200 text-green-800 text-sm font-medium flex items-center gap-2.5">
          <svg class="size-5 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <span class="font-bold">{lang === 'en' ? 'Payment Successful!' : 'Pembayaran Berhasil!'}</span>
            <span class="block text-xs mt-0.5 text-green-700">
              {lang === 'en' ? 'Thank you for your purchase. You will receive a receipt and details shortly via email.' : 'Terima kasih atas pembelian Anda. Rincian produk akan segera dikirimkan ke email Anda.'}
            </span>
          </div>
        </div>
      )}
      {Astro.url.searchParams.get('payment') === 'failed' && (
        <div class="mb-8 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 text-sm font-medium flex items-center gap-2.5">
          <svg class="size-5 text-red-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div>
            <span class="font-bold">{lang === 'en' ? 'Payment Failed or Cancelled' : 'Pembayaran Gagal atau Dibatalkan'}</span>
            <span class="block text-xs mt-0.5 text-red-700">
              {lang === 'en' ? 'The checkout process was not completed. Please try again if this was a mistake.' : 'Proses checkout tidak selesai. Silakan coba kembali.'}
            </span>
          </div>
        </div>
      )}

      <div>
        <div class="flex flex-wrap justify-between gap-4 items-start">
          <div class="max-w-xl text-balance">
            <Text
              tag="h1"
              variant="displayLG"
              class="text-base-900 font-display font-thin"
            >
              {frontmatter.title}
            </Text>
            <Text tag="p" variant="textBase" class="text-base-600 mt-4">
              {frontmatter.description}
            </Text>
          </div>
          <div class="flex items-center gap-3 shrink-0 self-start mt-2">
            <Button
              size="base"
              variant="default"
              href={`/api/store/create-invoice?slug=${Astro.params.slug}`}
              class="font-semibold shadow-sm px-6"
            >
              Buy for ${frontmatter.price}
            </Button>
            <Button
              isLink
              size="base"
              variant="muted"
              href={frontmatter.live}
              target="_blank"
              class="font-semibold border border-base-200"
            >
              Live Demo
            </Button>
          </div>
        </div>
        <div class="p-8 bg-base-50 rounded-lg mt-12">
          <Image
            width={1400}
            height={1400}
            loading="lazy"
            decoding="async"
            src={frontmatter.image.url}
            alt={frontmatter.image.alt ?? frontmatter.title}
            class="size-full aspect-8/5 object-top rounded shadow"
          />
        </div>
        <dl class="mt-4 divide-y divide-base-100">
          {
            frontmatter.features.map((feature) => (
              <div class="flex itmes-center gap-2 justify-between py-2">
                <dt>
                  <Text
                    tag="h3"
                    variant="textSM"
                    class="text-base-900 font-medium"
                  >
                    {feature.title}
                  </Text>
                </dt>
                <dd class="mt-1">
                  <Text tag="p" variant="textSM" class="text-base-600">
                    {feature.description}
                  </Text>
                </dd>
              </div>
            ))
          }
          
          <Text tag="p" variant="textSM" class="text-base-600 mt-4">
            {frontmatter.license}
          </Text>
        </dl>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {
          frontmatter.gallery.map((img) => (
            <div class="p-8 bg-base-50 rounded-lg mt-12">
              <Image
                width={1400}
                height={1400}
                loading="lazy"
                decoding="async"
                src={img.url}
                alt={img.alt ?? frontmatter.title}
                class="size-full aspect-8/5 object-top rounded shadow"
              />
            </div>
          ))
        }
      </div>
    </Wrapper>
  </section>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-wrap gap-4 justify-between items-center">
        <Text
          tag="h2"
          variant="displaySM"
          class="text-base-900 font-display font-thin">{t('store.moreProducts')}</Text
        >
        <Button isLink size="sm" variant="muted" href="/store/">
          {t('store.seeAllProducts')}
        </Button>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 mt-8">
        {allstore.slice(0, 3).map((post) => <StoreCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
