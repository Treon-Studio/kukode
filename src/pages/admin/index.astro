---
import { Effect } from 'effect';
import Text from '@/components/fundations/elements/Text.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { IAdminRepository } from '@/domain/admin';
import AdminLayout from '@/layouts/AdminLayout.astro';

const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;

if (!user || profile?.role !== 'admin') {
  return Astro.redirect('/signin');
}

const appRuntime = createAppRuntime(Astro.locals);

const [pendingSites, overviewData] = await appRuntime.runPromise(Effect.all([
  Effect.gen(function* () {
    const repo = yield* IAdminRepository;
    return yield* repo.getPendingSites();
  }),
  Effect.gen(function* () {
    const repo = yield* IAdminRepository;
    return yield* repo.getAnalyticsOverview();
  }),
], { concurrency: 'unbounded' }));
---

<AdminLayout title="Admin Overview">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="rounded-lg border border-base-200 p-6">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        Pending Review
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {pendingSites?.length ?? 0}
      </Text>
      <Text tag="p" variant="textXS" class="text-base-400 mt-1">
        {pendingSites?.length ?? 0} products waiting for review
      </Text>
    </div>
    <div class="rounded-lg border border-base-200 p-6">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        Approved Sites
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {overviewData?.approvedSitesCount ?? 0}
      </Text>
      <Text tag="p" variant="textXS" class="text-base-400 mt-1">
        {overviewData?.sitesCount ?? 0} total submissions
      </Text>
    </div>
    <div class="rounded-lg border border-base-200 p-6">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        Total Users
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {overviewData?.usersCount ?? 0}
      </Text>
      <Text tag="p" variant="textXS" class="text-base-400 mt-1">
        {overviewData?.votesCount ?? 0} votes, {overviewData?.commentsCount ?? 0} comments
      </Text>
    </div>
  </div>
</AdminLayout>