---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Logo from '@/components/global/Logo.astro';
import MobileNav from './MobileNav.astro';

// Get user and profile from middleware (Astro.locals)
const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;
const isLoggedIn = !!user;

// Quick access links
const links = [
  { href: '/system/overview', text: 'Overview' },
  { href: '/', text: 'Websites' },
  { href: '/pricing/', text: 'Pricing' },
  { href: '/blog/', text: 'Blog' },
  { href: '/store/', text: 'Store' },
  { href: '/submit/', text: 'Submit' },
  { href: '/advertise/', text: 'Sponsors' },
  { href: 'https://treonstudio.com/templates/carbon', text: 'Buy Carbon' },
];
---

<MobileNav />
<nav class="fixed w-full top-0 z-20 bg-white py-4 hidden md:block">
  <Wrapper variant="standard">
    <div
      class="grid grid-cols-2 md:grid-cols-2 items-center w-full gap-3 relative"
    >
      <a
        href="/"
        class="shrink-0 foucs:outline-none"
        aria-label="Go to homepage"
      >
        <Logo class="h-4 text-base-900" />
      </a>
      <div class="flex items-center gap-2 lg:gap-2 ml-auto">
        <div class="flex items-center gap-4">
          {
            links.map((link) => (
              <a
                class="text-base-600 hover:text-base-900 text-xs whitespace-nowrap"
                href={link.href}
              >
                {link.text}
              </a>
            ))
          }
        </div>

        {isLoggedIn ? (
          <div class="relative" data-user-dropdown>
            <button
              type="button"
              class="flex items-center gap-2 shrink-0 rounded-full focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2"
              data-user-dropdown-toggle
              aria-expanded="false"
              aria-haspopup="true"
            >
              {profile?.avatar_url ? (
                <img
                  src={profile.avatar_url}
                  alt={profile.full_name || profile.username || 'Avatar'}
                  class="size-8 rounded-full object-cover ring-1 ring-base-200"
                />
              ) : (
                <div class="size-8 rounded-full bg-accent-100 text-accent-600 flex items-center justify-center text-xs font-semibold ring-1 ring-base-200">
                  {(profile?.username || user.email || 'U').charAt(0).toUpperCase()}
                </div>
              )}
            </button>
            {/* Dropdown menu */}
            <div
              class="hidden absolute right-0 mt-2 w-48 rounded-lg bg-white shadow-lg ring-1 ring-base-200 py-1 z-50"
              data-user-dropdown-menu
            >
              <div class="px-4 py-2 border-b border-base-100">
                <p class="text-xs font-medium text-base-900 truncate">
                  {profile?.full_name || profile?.username || 'User'}
                </p>
                <p class="text-xs text-base-500 truncate">{user.email}</p>
              </div>
              <a
                href="/dashboard"
                class="block px-4 py-2 text-xs text-base-700 hover:bg-base-50"
              >
                Dashboard
              </a>
              <a
                href="/dashboard/settings"
                class="block px-4 py-2 text-xs text-base-700 hover:bg-base-50"
              >
                Settings
              </a>
              {profile?.role === 'admin' && (
                <a
                  href="/admin"
                  class="block px-4 py-2 text-xs text-base-700 hover:bg-base-50"
                >
                  Admin Panel
                </a>
              )}
              <form method="POST" action="/api/auth/signout" class="border-t border-base-100">
                <button
                  type="submit"
                  class="w-full text-left px-4 py-2 text-xs text-red-600 hover:bg-red-50"
                >
                  Sign out
                </button>
              </form>
            </div>
          </div>
        ) : (
          <>
            <Button isLink size="xs" variant="muted" href="/signin" class="shrink-0"
              >Sign in</Button
            >
            <Button
              isLink
              size="xs"
              variant="default"
              href="/signup"
              class="shrink-0">Sign up</Button
            >
          </>
        )}
      </div>
    </div>
  </Wrapper>
</nav>

<script is:inline>
  // User dropdown toggle
  (() => {
    const container = document.querySelector('[data-user-dropdown]');
    if (!container) return;
    const toggle = container.querySelector('[data-user-dropdown-toggle]');
    const menu = container.querySelector('[data-user-dropdown-menu]');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target)) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
