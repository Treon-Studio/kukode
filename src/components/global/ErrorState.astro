---
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';

interface Props {
  title?: string;
  description?: string;
  icon?: string; // e.g. ri-error-warning-line
  actionText?: string;
  actionHref?: string;
  showRetry?: boolean;
  class?: string;
}

const {
  title = 'Terjadi Kesalahan',
  description = 'Gagal memuat data. Silakan coba beberapa saat lagi atau hubungi tim bantuan kami.',
  icon = 'ri-spam-3-line',
  actionText,
  actionHref,
  showRetry = false,
  class: className = '',
} = Astro.props;
---

<div class={`flex flex-col items-center justify-center text-center p-8 md:p-12 rounded-2xl bg-red-50/30 border border-red-100 backdrop-blur-sm shadow-sm transition duration-300 hover:border-red-200/80 ${className}`}>
  <!-- Icon Wrapper with danger-style glow -->
  <div class="relative flex items-center justify-center size-14 rounded-2xl bg-white ring-1 ring-red-100 shadow-md mb-5 group">
    <div class="absolute inset-0 rounded-2xl bg-gradient-to-tr from-red-500/10 to-orange-500/10 opacity-100 transition duration-300"></div>
    <i class={`${icon} text-2xl text-red-500 animate-pulse`}></i>
  </div>

  <Text tag="h3" variant="textBase" class="text-base-900 font-display font-medium">
    {title}
  </Text>
  
  <Text tag="p" variant="textXS" class="text-base-500 mt-2 max-w-sm text-balance">
    {description}
  </Text>

  <div class="flex items-center gap-3 mt-6">
    {showRetry && (
      <Button size="sm" variant="muted" onclick="window.location.reload();" class="cursor-pointer">
        Coba Lagi
      </Button>
    )}
    {actionText && actionHref && (
      <Button isLink size="sm" variant="accent" href={actionHref}>
        {actionText}
      </Button>
    )}
  </div>
</div>
