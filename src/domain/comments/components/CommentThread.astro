---
import Button from '@/components/fundations/elements/Button.astro';
import CommentItem from './CommentItem.astro';

// We import the Comment type from CommentItem indirectly or define it here
interface Comment {
  id: string;
  author: {
    username: string;
    avatarUrl?: string;
  };
  content: string;
  createdAt: string;
  upvotes: number;
  replies?: Comment[];
}

interface Props {
  comments: Comment[];
  isLoggedIn?: boolean;
}

const { comments, isLoggedIn = false } = Astro.props;
---

<div class="comments-section mt-10">
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-xl font-bold text-base-900 font-display">Discussion ({comments.length})</h3>
  </div>

  <!-- Main Comment Form -->
  <div class="mb-10 bg-white p-4 md:p-6 rounded-2xl border border-base-200 shadow-sm">
    {isLoggedIn ? (
      <form id="main-comment-form" class="flex flex-col gap-3">
        <textarea
          rows="3"
          class="w-full text-sm p-3 md:p-4 border border-base-200 rounded-xl bg-base-50 focus:bg-white focus:outline-none focus:ring-2 focus:ring-accent-500/20 focus:border-accent-500 transition-colors resize-y min-h-[100px]"
          placeholder="What are your thoughts?"
          required
        ></textarea>
        <div class="flex justify-end">
          <Button size="sm" variant="accent" type="submit">Post Comment</Button>
        </div>
      </form>
    ) : (
      <div class="text-center py-6">
        <p class="text-sm text-base-600 mb-4">Log in to join the discussion.</p>
        <div class="flex justify-center gap-3">
          <Button isLink size="sm" variant="muted" href="/signin" data-auth-trigger="signin">Log In</Button>
          <Button isLink size="sm" variant="accent" href="/signup" data-auth-trigger="signup">Sign Up</Button>
        </div>
      </div>
    )}
  </div>

  <!-- Comment Thread -->
  <div id="comment-thread-container" class="space-y-2">
    {comments.length > 0 ? (
      comments.map((comment) => (
        <CommentItem comment={comment} depth={0} />
      ))
    ) : (
      <div class="text-center py-10 bg-base-50 rounded-2xl border border-base-100 border-dashed">
        <p class="text-sm text-base-500">No comments yet. Be the first to share your thoughts!</p>
      </div>
    )}
  </div>
</div>

<script>
  // Interactive functionality for nested comments
  document.addEventListener('DOMContentLoaded', () => {
    const threadContainer = document.getElementById('comment-thread-container');
    if (!threadContainer) return;

    // Delegate events for dynamically added/rendered comments
    threadContainer.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      // 1. Handle "Reply" button click
      const replyBtn = target.closest('.comment-reply-btn');
      if (replyBtn) {
        e.preventDefault();
        const commentItem = replyBtn.closest('.comment-item');
        if (commentItem) {
          const formContainer = commentItem.querySelector(':scope > div > .flex-1 > .reply-form-container');
          if (formContainer) {
            formContainer.classList.toggle('hidden');
            if (!formContainer.classList.contains('hidden')) {
              const textarea = formContainer.querySelector('textarea');
              if (textarea) textarea.focus();
            }
          }
        }
        return;
      }

      // 2. Handle "Cancel" button in reply form
      const cancelBtn = target.closest('.cancel-reply-btn');
      if (cancelBtn) {
        e.preventDefault();
        const formContainer = cancelBtn.closest('.reply-form-container');
        if (formContainer) {
          formContainer.classList.add('hidden');
          const textarea = formContainer.querySelector('textarea');
          if (textarea) textarea.value = '';
        }
        return;
      }

      // 3. Handle "Collapse/Expand" button
      const toggleBtn = target.closest('.comment-toggle-btn');
      if (toggleBtn) {
        e.preventDefault();
        const commentItem = toggleBtn.closest('.comment-item');
        if (commentItem) {
          const repliesContainer = commentItem.querySelector(':scope > div > .flex-1 > .replies-container');
          if (repliesContainer) {
            const isHidden = repliesContainer.classList.contains('hidden');
            if (isHidden) {
              repliesContainer.classList.remove('hidden');
              toggleBtn.textContent = '[–] Collapse';
            } else {
              repliesContainer.classList.add('hidden');
              toggleBtn.textContent = '[+] Expand';
            }
          }
        }
        return;
      }

      // 4. Handle "Upvote" button
      const upvoteBtn = target.closest('.comment-upvote-btn');
      if (upvoteBtn) {
        e.preventDefault();
        // Optimistic UI update
        const countSpan = upvoteBtn.querySelector('span');
        if (countSpan) {
          const currentCount = parseInt(countSpan.textContent || '0', 10);
          const isUpvoted = upvoteBtn.classList.contains('text-accent-600');
          
          if (isUpvoted) {
            countSpan.textContent = (currentCount - 1).toString();
            upvoteBtn.classList.remove('text-accent-600', 'bg-accent-50');
          } else {
            countSpan.textContent = (currentCount + 1).toString();
            upvoteBtn.classList.add('text-accent-600', 'bg-accent-50', 'rounded', 'px-1');
          }
          // Note: In a real app, send an API request here to persist the upvote.
        }
        return;
      }
    });

    // Handle Reply Form Submissions
    threadContainer.addEventListener('submit', (e) => {
      const target = e.target as HTMLFormElement;
      if (target.closest('.reply-form-container')) {
        e.preventDefault();
        const textarea = target.querySelector('textarea');
        const content = textarea?.value.trim();
        if (!content) return;
        
        // Disable form while submitting
        const submitBtn = target.querySelector('button[type="submit"]');
        if (submitBtn) {
           submitBtn.textContent = 'Posting...';
           submitBtn.setAttribute('disabled', 'true');
        }

        // Mock API Call delay
        setTimeout(() => {
          alert('Comment replied successfully (Mock). In a real app, this would re-render the thread or inject the new DOM node.');
          
          // Reset form
          if (textarea) textarea.value = '';
          const formContainer = target.closest('.reply-form-container');
          if (formContainer) formContainer.classList.add('hidden');
          if (submitBtn) {
             submitBtn.textContent = 'Reply';
             submitBtn.removeAttribute('disabled');
          }
        }, 500);
      }
    });

    // Handle Main Comment Form Submission
    const mainForm = document.getElementById('main-comment-form');
    if (mainForm) {
      mainForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const textarea = mainForm.querySelector('textarea');
        const content = textarea?.value.trim();
        if (!content) return;

        const submitBtn = mainForm.querySelector('button[type="submit"]');
        if (submitBtn) {
           submitBtn.textContent = 'Posting...';
           submitBtn.setAttribute('disabled', 'true');
        }

        // Mock API Call delay
        setTimeout(() => {
          alert('Main comment posted successfully (Mock). In a real app, this would re-render the thread or inject the new DOM node.');
          
          // Reset form
          if (textarea) textarea.value = '';
          if (submitBtn) {
             submitBtn.textContent = 'Post Comment';
             submitBtn.removeAttribute('disabled');
          }
        }, 500);
      });
    }
  });
</script>
