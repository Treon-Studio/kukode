---
import { Effect } from 'effect';
import Text from '@/components/fundations/elements/Text.astro';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { getPlatformStatsProgram } from '@/domain/analytics';
import { IAdminRepository } from '@/domain/admin';
import { createAppRuntime } from '@/infra/runtime/app.runtime';

const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;

if (!user || profile?.role !== 'admin') {
  return Astro.redirect('/signin');
}

// 1. Fetch DAU/MAU from Redis HyperLogLog
const env = Astro.locals.runtime?.env;
const appRuntime = createAppRuntime(env);
const { dau, mau } = await appRuntime.runPromise(getPlatformStatsProgram());

// 2. Fetch platform aggregates and recent transactions
const overviewData = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* IAdminRepository;
  return yield* repo.getAnalyticsOverview();
}));

const {
  usersCount,
  sitesCount,
  votesCount,
  commentsCount,
  totalRevenue,
  recentTransactions,
} = overviewData;
---

<AdminLayout title="Platform Analytics">
  <div class="mb-8">
    <Text tag="p" variant="textSM" class="text-base-600">
      Platform metrics, unique visitors tracking, and transaction records.
    </Text>
  </div>

  {/* Metrics Grid */}
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Daily Active Users (DAU)</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{dau}</span>
    </div>
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Monthly Active (MAU)</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{mau}</span>
    </div>
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Total Members</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{usersCount}</span>
    </div>
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Total Submissions</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{sitesCount}</span>
    </div>
  </div>

  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Total Votes</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{votesCount}</span>
    </div>
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Total Comments</span>
      <span class="text-2xl font-bold text-base-900 block mt-1.5">{commentsCount}</span>
    </div>
    <div class="bg-white border border-base-200 p-5 rounded-2xl shadow-sm col-span-2">
      <span class="text-xs font-semibold text-base-400 uppercase tracking-wider block">Total Completed Revenue</span>
      <span class="text-2xl font-bold text-green-600 block mt-1.5">${totalRevenue.toLocaleString()}</span>
    </div>
  </div>

  {/* Recent Transactions */}
  <div class="bg-white border border-base-200 rounded-2xl shadow-sm p-6">
    <Text tag="h3" variant="textBase" class="text-base-900 font-semibold mb-4">
      Recent Purchases & sponsored logs
    </Text>
    
    {(!recentTransactions || recentTransactions.length === 0) ? (
      <p class="text-sm text-base-400 italic py-4">No transactions recorded yet.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full text-left text-xs border-collapse">
          <thead>
            <tr class="border-b border-base-100 text-base-400 font-semibold uppercase tracking-wider">
              <th class="pb-3 pr-4 font-semibold">User</th>
              <th class="pb-3 px-4 font-semibold">Item</th>
              <th class="pb-3 px-4 font-semibold">Amount</th>
              <th class="pb-3 px-4 font-semibold">Status</th>
              <th class="pb-3 pl-4 font-semibold">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base-50 text-base-700">
            {recentTransactions.map((tx: any) => (
              <tr>
                <td class="py-3.5 pr-4 font-medium">@{tx.username || 'unknown'}</td>
                <td class="py-3.5 px-4 font-mono">{tx.store_slug}</td>
                <td class="py-3.5 px-4 font-semibold text-base-900">${tx.amount}</td>
                <td class="py-3.5 px-4">
                  {tx.status === 'completed' && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full font-semibold bg-green-50 text-green-700 border border-green-200">
                      Paid
                    </span>
                  )}
                  {tx.status === 'pending' && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full font-semibold bg-yellow-50 text-yellow-700 border border-yellow-200">
                      Pending
                    </span>
                  )}
                  {tx.status === 'failed' && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full font-semibold bg-red-50 text-red-700 border border-red-200">
                      Failed
                    </span>
                  )}
                </td>
                <td class="py-3.5 pl-4 text-base-400">
                  {new Date(tx.created_at).toLocaleDateString('id-ID', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric'
                  })}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>
</AdminLayout>
