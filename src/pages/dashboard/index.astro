---
import { Effect } from 'effect';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import EmptyState from '@/components/global/EmptyState.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { ISiteRepository } from '@/domain/site';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;

const appRuntime = createAppRuntime(Astro.locals);
const stats = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* ISiteRepository;
  return yield* repo.getCreatorDashboardStats(user.id);
}));

const submittedCount = stats.submittedCount;
const approvedCount = stats.approvedCount;
const totalViews = stats.totalViews;
const totalVotes = stats.totalVotes;

// Badge Logic
let badge = null;
if (approvedCount && approvedCount >= 5) {
  badge = { label: 'Top Maker', class: 'bg-yellow-100 text-yellow-800 border-yellow-200' };
} else if (approvedCount && approvedCount >= 3) {
  badge = { label: 'Pro Maker', class: 'bg-purple-100 text-purple-800 border-purple-200' };
} else if (approvedCount && approvedCount >= 1) {
  badge = { label: 'Maker', class: 'bg-green-100 text-green-800 border-green-200' };
}
---

<DashboardLayout title="Dashboard">
  <div class="flex items-center gap-3 mb-8">
    <Text tag="p" variant="textBase" class="text-base-600">
      {t('dashboard.welcome')} <strong class="text-base-900">{profile?.full_name || profile?.username || 'Maker'}</strong>!
    </Text>
    {badge && (
      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${badge.class}`}>
        {badge.label}
      </span>
    )}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
    <a href="/dashboard/products" class="block rounded-lg border border-base-200 p-6 hover:border-accent-300 hover:shadow-sm transition-all">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        {t('dashboard.submitted')}
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {submittedCount || 0}
      </Text>
      <Text tag="p" variant="textXS" class="text-base-400 mt-1">
        {approvedCount || 0} {t('dashboard.approved')}
      </Text>
    </a>
    <a href="/dashboard/products" class="block rounded-lg border border-base-200 p-6 hover:border-accent-300 hover:shadow-sm transition-all">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        {t('dashboard.totalVotes')}
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {totalVotes}
      </Text>
    </a>
    <a href="/dashboard/products" class="block rounded-lg border border-base-200 p-6 hover:border-accent-300 hover:shadow-sm transition-all">
      <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-wider">
        {t('dashboard.totalViews')}
      </Text>
      <Text tag="p" variant="displaySM" class="text-base-900 font-display mt-1">
        {totalViews}
      </Text>
    </a>
  </div>

  {(!submittedCount || submittedCount === 0) && (
    <EmptyState
      title={t('dashboard.emptyTitle')}
      description={t('dashboard.emptyDesc')}
      icon="ri-rocket-line"
      actionText={t('dashboard.emptyAction')}
      actionHref="/submit"
    />
  )}

</DashboardLayout>
