---
interface Props {
  id?: string;
  name?: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  minlength?: string | number;
  class?: string;
}

const {
  id = 'password',
  name = 'password',
  label,
  placeholder = '••••••••',
  required = true,
  minlength,
  class: className = '',
  ...rest
} = Astro.props;
---

<div class={`w-full ${className}`} {...rest}>
  {label && (
    <div class="flex items-baseline justify-between mb-1">
      <label for={id} class="text-sm font-medium text-base-500">
        {label} {required && <span class="text-red-500">*</span>}
      </label>
    </div>
  )}
  <div class="relative z-0 focus-within:z-10 flex items-center">
    <input
      required={required}
      id={id}
      name={name}
      type="password"
      minlength={minlength}
      placeholder={placeholder}
      class="block w-full pl-4 pr-10 py-2 text-xs leading-tight align-middle bg-white border border-transparent transition duration-300 ease-in-out focus:z-10 h-9 rounded-md text-base-500 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
      aria-required={required ? 'true' : 'false'}
    />
    <button
      type="button"
      class="absolute right-3 text-base-400 hover:text-base-600 focus:outline-none cursor-pointer flex items-center"
      data-toggle-password={id}
      aria-label="Toggle password visibility"
    >
      <svg class="size-4 show-pass" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
        <circle cx="12" cy="12" r="3"/>
      </svg>
      <svg class="size-4 hide-pass hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
        <line x1="1" y1="1" x2="23" y2="23"/>
      </svg>
    </button>
  </div>
</div>

<script>
  function setupPasswordToggles() {
    document.querySelectorAll('[data-toggle-password]').forEach((btn) => {
      if ((btn as any).__hasToggleListener) return;
      (btn as any).__hasToggleListener = true;

      btn.addEventListener('click', () => {
        const inputId = btn.getAttribute('data-toggle-password');
        const input = document.getElementById(inputId || '');
        if (!input) return;

        const isPassword = input.getAttribute('type') === 'password';
        input.setAttribute('type', isPassword ? 'text' : 'password');

        const showIcon = btn.querySelector('.show-pass');
        const hideIcon = btn.querySelector('.hide-pass');

        if (isPassword) {
          showIcon?.classList.add('hidden');
          hideIcon?.classList.remove('hidden');
        } else {
          showIcon?.classList.remove('hidden');
          hideIcon?.classList.add('hidden');
        }
      });
    });
  }

  // Hook into both standard load and potential routing events
  document.addEventListener('DOMContentLoaded', setupPasswordToggles);
  document.addEventListener('astro:page-load', setupPasswordToggles);
  setupPasswordToggles();
</script>
