---
import { Effect } from 'effect';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import UserAvatar from '@/components/global/UserAvatar.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { IAuthRepository } from '@/domain/auth';
import { getClientDict, getLangFromLocals, useTranslations } from '@/i18n/utils';
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { APP_CONFIG } from '@/lib/constants';
import { runStorageEffect, StorageAdapter } from '@/lib/storage';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
const clientDict = getClientDict(lang);

const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;

const appRuntime = createAppRuntime(Astro.locals);

// Handle form submission
let successMsg = '';
let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const fullName = formData.get('full_name')?.toString() || '';
  const username = formData.get('username')?.toString() || '';
  const bio = formData.get('bio')?.toString() || '';
  const website = formData.get('website')?.toString() || '';
  const twitter = formData.get('twitter')?.toString() || '';
  const github = formData.get('github')?.toString() || '';
  const avatarFile = formData.get('avatar_file') as File | null;

  // Validation checks
  const usernameRegex = /^[a-zA-Z0-9_-]+$/;
  if (username && !usernameRegex.test(username)) {
    errorMsg = t('settings.usernameInvalid');
  } else if (website && !/^https?:\/\//i.test(website)) {
    errorMsg = t('settings.websiteInvalid');
  }

  // Check username uniqueness (if changed)
  if (!errorMsg && username && username !== profile?.username) {
    const isTaken = await appRuntime.runPromise(Effect.gen(function* () {
      const repo = yield* IAuthRepository;
      return yield* repo.checkUsernameTaken(username, user.id);
    }));

    if (isTaken) {
      errorMsg = t('settings.usernameUsed');
    }
  }

  let newAvatarUrl = profile?.avatar_url;
  if (!errorMsg && avatarFile && avatarFile.size > 0) {
    if (avatarFile.size > 2 * 1024 * 1024) {
      errorMsg = t('settings.avatarTooLarge');
    } else if (!avatarFile.type.startsWith('image/')) {
      errorMsg = t('settings.avatarNotImage');
    }

    if (!errorMsg) {
      try {
        const uploadEffect = StorageAdapter.pipe(
          Effect.flatMap((storage) => storage.uploadFile(avatarFile, 'avatars'))
        );
        const result = await runStorageEffect(uploadEffect, Astro.locals);
        newAvatarUrl = result.url;
      } catch (e: any) {
        errorMsg = e.message || 'Gagal mengupload avatar';
      }
    }
  }

  if (!errorMsg) {
    try {
      await appRuntime.runPromise(Effect.gen(function* () {
        const repo = yield* IAuthRepository;
        yield* repo.updateUserProfile(user.id, {
          full_name: fullName,
          username: username || profile?.username,
          avatar_url: newAvatarUrl,
          bio,
          website,
          twitter,
          github,
        });
      }));

      successMsg = t('settings.successUpdate');
    } catch (e: any) {
      errorMsg = e.message || t('settings.failUpdate');
    }
  }
}

// Re-fetch profile after update
const currentProfile = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* IAuthRepository;
  return yield* repo.getUserProfile(user.id);
}));

// Fetch user's passkeys
const userPasskeys = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* IAuthRepository;
  return yield* repo.getUserPasskeys(user.id);
}));
---

<DashboardLayout title="Settings">
  {successMsg && <script define:vars={{ successMsg }}>window.addEventListener('DOMContentLoaded', () => window.toast.success(successMsg))</script>}
  {errorMsg && <script define:vars={{ errorMsg }}>window.addEventListener('DOMContentLoaded', () => window.toast.error(errorMsg))</script>}

  <form method="POST" enctype="multipart/form-data" class="space-y-6 max-w-lg">
    <div>
      <label class="block text-sm font-medium text-base-700 mb-1">
        {t('settings.avatarLabel')}
      </label>
      <div class="flex items-center gap-4">
        <UserAvatar
          avatarUrl={currentProfile?.avatar_url}
          username={currentProfile?.username}
          email={user.email}
          class="size-16"
        />
        <div class="flex-1">
          <input
            id="avatar_file"
            name="avatar_file"
            type="file"
            accept="image/*"
            class="block w-full text-xs text-base-500 file:mr-4 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-base-900 file:text-white hover:file:bg-base-800 transition cursor-pointer"
          />
          <p class="text-[10px] text-base-400 mt-1">
            {t('settings.avatarHelp')}
          </p>
        </div>
      </div>
    </div>

    <div>
      <label for="username" class="block text-sm font-medium text-base-700 mb-1">
        Username
      </label>
      <input
        id="username"
        name="username"
        type="text"
        value={currentProfile?.username || ''}
        class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
        placeholder="your-username"
      />
      <p class="text-xs text-base-400 mt-1">URL: {new URL(APP_CONFIG.BASE_URL).host}/u/{currentProfile?.username || 'username'}</p>
    </div>

    <div>
      <label for="full_name" class="block text-sm font-medium text-base-700 mb-1">
        {t('settings.fullName')}
      </label>
      <input
        id="full_name"
        name="full_name"
        type="text"
        value={currentProfile?.full_name || ''}
        class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
        placeholder="Budi Santoso"
      />
    </div>

    <div>
      <label for="bio" class="block text-sm font-medium text-base-700 mb-1">
        {t('settings.bio')}
      </label>
      <textarea
        id="bio"
        name="bio"
        rows="3"
        class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
        placeholder={t('settings.bioPlaceholder')}
      >{currentProfile?.bio || ''}</textarea>
    </div>

    <div>
      <label for="website" class="block text-sm font-medium text-base-700 mb-1">
        {t('settings.website')}
      </label>
      <input
        id="website"
        name="website"
        type="url"
        value={currentProfile?.website || ''}
        class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
        placeholder="https://yoursite.com"
      />
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label for="twitter" class="block text-sm font-medium text-base-700 mb-1">
          Twitter/X
        </label>
        <input
          id="twitter"
          name="twitter"
          type="text"
          value={currentProfile?.twitter || ''}
          class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
          placeholder="@username"
        />
      </div>
      <div>
        <label for="github" class="block text-sm font-medium text-base-700 mb-1">
          GitHub
        </label>
        <input
          id="github"
          name="github"
          type="text"
          value={currentProfile?.github || ''}
          class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
          placeholder="username"
        />
      </div>
    </div>

    <Button size="sm" variant="accent" type="submit">
      {t('settings.saveChanges')}
    </Button>
  </form>

  <div class="mt-12 pt-8 border-t border-base-200 max-w-lg" data-lang={lang} id="passkeys-container">
    <h3 class="text-lg font-semibold text-base-800 mb-2">{t('settings.passkeysTitle')}</h3>
    <p class="text-sm text-base-500 mb-6">
      {t('settings.passkeysDesc')}
    </p>

    <!-- Passkeys List -->
    <div class="space-y-3 mb-6" id="passkeys-list">
      {userPasskeys.length === 0 ? (
        <div class="text-sm text-base-400 italic bg-base-50 rounded-lg p-4 border border-base-200">
          {t('settings.noPasskeys')}
        </div>
      ) : (
        userPasskeys.map((pk) => (
          <div class="flex items-center justify-between bg-white border border-base-200 rounded-lg p-4 shadow-sm" id={`pk-${pk.id}`}>
            <div>
              <p class="text-sm font-semibold text-base-700">Passkey</p>
              <p class="text-xs text-base-400">
                {t('settings.passkeyCreated')}{' '}
                {new Date(pk.created_at).toLocaleDateString(lang === 'id' ? 'id-ID' : lang === 'jv' ? 'jv-ID' : lang === 'ms' ? 'ms-MY' : lang === 'bjn' ? 'id-ID' : 'en-US', {
                  dateStyle: 'medium',
                })}
              </p>
            </div>
            <button
              class="delete-pk-btn text-xs text-red-600 hover:text-red-800 font-medium transition duration-200"
              data-id={pk.id}
            >
              {t('settings.passkeyRemove')}
            </button>
          </div>
        ))
      )}
    </div>

    <button
      id="register-passkey-btn"
      class="inline-flex items-center justify-center px-4 py-2 text-xs font-semibold rounded-lg bg-base-800 text-white hover:bg-base-900 transition duration-200 focus:outline-none focus:ring-2 focus:ring-base-500 focus:ring-offset-2"
    >
      {t('settings.passkeyRegister')}
    </button>
    <p id="passkey-error" class="text-xs text-red-500 mt-2 hidden"></p>
    <p id="passkey-success" class="text-xs text-green-600 mt-2 hidden"></p>
  </div>
</DashboardLayout>

<script type="application/json" id="i18n-dict" set:html={JSON.stringify(clientDict)} />
<script>
  import 'webauthn-polyfills';
  import { FileLifecycleStateMachine } from '@/lib/storage/state-machine';

  document.addEventListener('DOMContentLoaded', () => {
    // Hydrate the active language dictionary for client-side use.
    const dictNode = document.getElementById('i18n-dict');
    const dict: Record<string, string> = dictNode?.textContent ? JSON.parse(dictNode.textContent) : {};
    const t = (key: string) => dict[key] ?? key;

    const registerBtn = document.getElementById('register-passkey-btn');
    const passkeyError = document.getElementById('passkey-error');
    const passkeySuccess = document.getElementById('passkey-success');

    if (registerBtn) {
      registerBtn.addEventListener('click', async () => {
        if (!passkeyError || !passkeySuccess) return;
        passkeyError.classList.add('hidden');
        passkeySuccess.classList.add('hidden');
        (registerBtn as HTMLButtonElement).disabled = true;
        const originalText = registerBtn.textContent;
        registerBtn.textContent = t('settings.passkeyGenerating');

        try {
          // 1. Fetch registration options from server
          const optionsRes = await fetch('/api/auth/passkey/register-options');
          if (!optionsRes.ok) {
            const errData = await optionsRes.json();
            throw new Error(errData.error || 'Failed to fetch options');
          }
          const options = await optionsRes.json();

          registerBtn.textContent = t('settings.passkeyWaiting');

          // 2. Call browser WebAuthn API
          const publicKey = PublicKeyCredential.parseCreationOptionsFromJSON(options);
          const credential = await navigator.credentials.create({
            publicKey,
          });

          if (!credential) {
            throw new Error(t('settings.passkeyFailedCreate'));
          }

          registerBtn.textContent = t('settings.passkeyVerifying');

          // 3. Send response back to server for verification
          const verifyRes = await fetch('/api/auth/passkey/register-verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify((credential as any).toJSON()),
          });

          if (!verifyRes.ok) {
            const errData = await verifyRes.json();
            throw new Error(errData.error || 'Verification failed');
          }

          passkeySuccess.textContent = t('settings.passkeyRegistered');
          passkeySuccess.classList.remove('hidden');
          setTimeout(() => window.location.reload(), 1500);
        } catch (err: any) {
          console.error(err);
          passkeyError.textContent = err.message || t('settings.passkeyRegistrationFailed');
          passkeyError.classList.remove('hidden');
          (registerBtn as HTMLButtonElement).disabled = false;
          registerBtn.textContent = originalText;
        }
      });
    }

    // Handle delete buttons
    const deleteBtns = document.querySelectorAll('.delete-pk-btn');
    deleteBtns.forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');

        const confirmed = await (window as any).confirmModal({
          title: t('settings.passkeyRemoveTitle'),
          message: t('settings.passkeyRemoveMessage'),
          confirmText: t('settings.passkeyRemove'),
          cancelText: t('common.cancel'),
          danger: true,
        });

        if (!confirmed) return;

        try {
          const res = await fetch('/api/auth/passkey/delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ passkey_id: id }),
          });

          if (!res.ok) {
            const errData = await res.json();
            throw new Error(errData.error || 'Failed to remove');
          }

          (window as any).toast.success(t('settings.passkeyRemoved'));

          const element = document.getElementById(`pk-${id}`);
          if (element) element.remove();

          const list = document.getElementById('passkeys-list');
          if (list && list.children.length === 0) {
            window.location.reload();
          }
        } catch (err: any) {
          (window as any).toast.error(err.message);
        }
      });
    });

    // Profile avatar input handling using FileLifecycleStateMachine
    const avatarInput = document.getElementById('avatar_file') as HTMLInputElement | null;
    const settingsForm = document.querySelector('form') as HTMLFormElement | null;
    const saveBtn = settingsForm?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

    if (avatarInput && settingsForm && saveBtn) {
      const uploaderMachine = new FileLifecycleStateMachine();
      const originalSaveText = saveBtn.textContent;

      uploaderMachine.subscribe((state) => {
        switch (state._tag) {
          case 'Idle':
            saveBtn.disabled = false;
            saveBtn.textContent = originalSaveText;
            break;
          case 'Uploading':
            saveBtn.disabled = true;
            saveBtn.textContent = t('settings.uploadingAvatar');
            break;
          case 'Uploaded':
            saveBtn.disabled = false;
            saveBtn.textContent = originalSaveText;
            break;
          case 'Failure':
            saveBtn.disabled = false;
            saveBtn.textContent = originalSaveText;
            (window as any).toast.error(state.error);
            break;
        }
      });

      settingsForm.addEventListener('submit', () => {
        if (avatarInput.files && avatarInput.files.length > 0) {
          uploaderMachine.transition({ _tag: 'StartUpload' });
        }
      });
    }
  });
</script>
