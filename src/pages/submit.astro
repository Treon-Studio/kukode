---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<BaseLayout
  seoProps={{
    title: t('submit.title'),
    description: t('submit.subtitle'),
    url: '/submit/',
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <Wrapper variant="narrow">
        <div class="text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="text-base-900 font-display font-thin"
          >
            {t('submit.title')}
          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="mt-2 text-base-600 text-balance"
          >
            {t('submit.subtitle')}
          </Text>
        </div>

        {/* Error/success messages from URL params */}
        <div id="submit-messages" class="mt-6"></div>

        <form
          method="POST"
          action="/api/sites/submit"
          class="mt-12 space-y-6 max-w-lg"
          id="submit-form"
        >
          <div>
            <label for="title" class="block text-sm font-medium text-base-700 mb-1">
              {t('submit.nameLabel')} <span class="text-red-500">*</span>
            </label>
            <input
              id="title"
              name="title"
              type="text"
              required
              placeholder={lang === 'en' ? 'Your product name' : 'Nama produk Anda'}
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="tagline" class="block text-sm font-medium text-base-700 mb-1">
              {t('submit.taglineLabel')} <span class="text-red-500">*</span>
              <span class="text-xs text-base-400 ml-1">({lang === 'en' ? 'max 60 chars' : 'maks 60 karakter'})</span>
            </label>
            <input
              id="tagline"
              name="tagline"
              type="text"
              required
              maxlength="60"
              placeholder={lang === 'en' ? 'Brief one-sentence tagline' : 'Deskripsi singkat satu kalimat'}
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
            <p class="text-xs text-base-400 mt-1"><span id="tagline-count">0</span>/60</p>
          </div>

          <div>
            <label for="live_url" class="block text-sm font-medium text-base-700 mb-1">
              {t('submit.urlLabel')} <span class="text-red-500">*</span>
            </label>
            <input
              id="live_url"
              name="live_url"
              type="url"
              required
              placeholder="https://your-product.com"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="description" class="block text-sm font-medium text-base-700 mb-1">
              {t('submit.descLabel')} <span class="text-red-500">*</span>
            </label>
            <textarea
              id="description"
              name="description"
              required
              rows="4"
              placeholder={lang === 'en' ? 'Tell us what your product does and why builders should check it out...' : 'Ceritakan apa yang produkmu lakukan dan mengapa developer harus mengeceknya...'}
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            ></textarea>
          </div>

          <div>
            <label for="tags" class="block text-sm font-medium text-base-700 mb-1">
              {lang === 'en' ? 'Tags' : 'Tag'}
              <span class="text-xs text-base-400 ml-1">({lang === 'en' ? 'separated by commas' : 'pisahkan dengan koma'})</span>
            </label>
            <input
              id="tags"
              name="tags"
              type="text"
              placeholder="astro, tailwind, productivity"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="thumbnail_url" class="block text-sm font-medium text-base-700 mb-1">
              {t('submit.thumbLabel')} <span class="text-red-500">*</span>
            </label>
            <input
              id="thumbnail_url"
              name="thumbnail_url"
              type="url"
              required
              placeholder="https://imgur.com/your-image.png"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div class="flex items-center gap-3">
            <Button size="sm" variant="accent" type="submit" id="submit-btn">
              {t('submit.button')}
            </Button>
            <Button isLink size="sm" variant="muted" href="/">
              {lang === 'en' ? 'Cancel' : 'Batal'}
            </Button>
          </div>
        </form>
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>

<script is:inline define:vars={{ lang }}>
  (() => {
    // Tagline character counter
    const tagline = document.getElementById('tagline');
    const counter = document.getElementById('tagline-count');
    if (tagline && counter) {
      tagline.addEventListener('input', () => {
        counter.textContent = tagline.value.length;
      });
    }

    // Show error/message from URL params
    const params = new URLSearchParams(window.location.search);
    const error = params.get('error');
    const message = params.get('message');
    const msgContainer = document.getElementById('submit-messages');

    if (error && msgContainer) {
      msgContainer.innerHTML = `<div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800" role="alert">${error}</div>`;
    }
    if (message && msgContainer) {
      msgContainer.innerHTML = `<div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800" role="status">${message}</div>`;
    }

    // Form submitting indicator
    const form = document.getElementById('submit-form');
    if (form) {
      form.addEventListener('submit', () => {
        const btn = document.getElementById('submit-btn');
        if (btn) {
          btn.setAttribute('disabled', 'true');
          btn.setAttribute('aria-busy', 'true');
          btn.textContent = lang === 'en' ? 'Submitting...' : 'Mengirim...';
        }
      });
    }
  })();
</script>
