---
// Retrieve all posts from the "sites" collection
import { getCollection } from 'astro:content';

const alltools = await getCollection('sites');
// Frontmatter
const { frontmatter, isDynamic = false } = Astro.props;

import { Image } from 'astro:assets';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import ArrowupRight from '@/components/fundations/icons/ArrowUpRight.astro';
import Comments from '@/components/sites/Comments.astro';
import SiteCard from '@/components/sites/SiteCard.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

const seoProps = {
  title: frontmatter.title,
  description: frontmatter.description,
  image: frontmatter.thumbnail?.url,
  url: Astro.url.href,
};
---

<BaseLayout showSearch={true} seoProps={seoProps}>
  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-wrap justify-between gap-4">
        <div class="max-w-xl text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="text-base-900 font-display font-thin capitalize"
          >
            {frontmatter.title}
          </Text>
          <Text tag="p" variant="textSM" class="text-base-600 mt-4">
            {frontmatter.description}
          </Text>
        </div>
        <Button
          iconOnly
          size="xs"
          variant="default"
          href={frontmatter.live}
          title={frontmatter.title}
          target="_blank"
        >
          <ArrowupRight slot="icon" class="size-4" />
        </Button>
      </div>
      <div class="p-8 bg-base-50 rounded-lg mt-12 relative group">
        {isDynamic ? (
          <img
            src={frontmatter.thumbnail.url}
            alt={frontmatter.thumbnail.alt || frontmatter.title}
            class="size-full aspect-8/5 object-top rounded shadow"
          />
        ) : (
          <Image
            width={1400}
            height={1400}
            loading="lazy"
            decoding="async"
            src={frontmatter.thumbnail.url}
            alt={frontmatter.thumbnail.alt}
            class="size-full aspect-8/5 object-top rounded shadow"
          />
        )}
      </div>
      <dl class="mt-4 divide-y divide-base-100 mb-12">
        {
          frontmatter.details?.map((details: any) => (
            <div class="flex itmes-center gap-2 justify-between py-2">
              <dt>
                <Text
                  tag="h3"
                  variant="textSM"
                  class="text-base-900 font-medium"
                >
                  {details.label}
                </Text>
              </dt>
              <dd>
                <Text tag="p" variant="textSM" class="text-base-600">
                  {details.value}
                </Text>
              </dd>
            </div>
          ))
        }
      </dl>

      {/* Content Slot for Markdown, or fallback description for Dynamic */}
      <div class="prose prose-base text-base-600 mb-12">
        <slot />
        {isDynamic && !Astro.slots.has('default') && (
          <p>{frontmatter.description}</p>
        )}
      </div>

      {/* Comments Section */}
      <hr class="border-base-100 my-12" />
      <Comments siteId={frontmatter.id} />
    </Wrapper>
  </section>

  <section>
    <Wrapper variant="standard" class="py-24">
      <div class="flex flex-wrap gap-4 justify-between items-center">
        <Text
          tag="h2"
          variant="displaySM"
          class="text-base-900 font-display font-thin">Latest additions</Text
        >
        <Button isLink size="sm" variant="muted" href="/sites/">
          See all tools
        </Button>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4 mt-8">
        {alltools.slice(0, 4).map((post) => <SiteCard post={post} />)}
      </div>
    </Wrapper>
  </section>
</BaseLayout>
