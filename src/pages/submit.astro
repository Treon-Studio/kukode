---
export const prerender = true;

import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  seoProps={{
    title: 'Submit Website',
    description: 'Submit your website to Kukode and get feedback from top builders and creators.',
    url: '/submit/',
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <Wrapper variant="narrow">
        <div class="text-balance">
          <Text
            tag="h1"
            variant="displayMD"
            class="text-base-900 font-display font-thin"
          >
            Submit produk kamu ke Kukode
          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="mt-2 text-base-600 text-balance"
          >
            Dapatkan eksposur dari developer dan desainer top Indonesia.
            Setiap submission direview dengan cermat.
          </Text>
        </div>

        {/* Error/success messages from URL params */}
        <div id="submit-messages" class="mt-6"></div>

        <form
          method="POST"
          action="/api/sites/submit"
          class="mt-12 space-y-6 max-w-lg"
          id="submit-form"
        >
          <div>
            <label for="title" class="block text-sm font-medium text-base-700 mb-1">
              Nama Produk <span class="text-red-500">*</span>
            </label>
            <input
              id="title"
              name="title"
              type="text"
              required
              placeholder="Nama produk kamu"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="tagline" class="block text-sm font-medium text-base-700 mb-1">
              Tagline <span class="text-red-500">*</span>
              <span class="text-xs text-base-400 ml-1">(maks 60 karakter)</span>
            </label>
            <input
              id="tagline"
              name="tagline"
              type="text"
              required
              maxlength="60"
              placeholder="Deskripsi singkat satu kalimat"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
            <p class="text-xs text-base-400 mt-1"><span id="tagline-count">0</span>/60</p>
          </div>

          <div>
            <label for="live_url" class="block text-sm font-medium text-base-700 mb-1">
              URL Produk <span class="text-red-500">*</span>
            </label>
            <input
              id="live_url"
              name="live_url"
              type="url"
              required
              placeholder="https://produk-kamu.com"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="description" class="block text-sm font-medium text-base-700 mb-1">
              Deskripsi <span class="text-red-500">*</span>
            </label>
            <textarea
              id="description"
              name="description"
              required
              rows="4"
              placeholder="Ceritakan apa yang produkmu lakukan dan mengapa developer harus mengeceknya..."
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            ></textarea>
          </div>

          <div>
            <label for="tags" class="block text-sm font-medium text-base-700 mb-1">
              Tags
              <span class="text-xs text-base-400 ml-1">(pisahkan dengan koma)</span>
            </label>
            <input
              id="tags"
              name="tags"
              type="text"
              placeholder="astro, tailwind, productivity"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div>
            <label for="thumbnail_url" class="block text-sm font-medium text-base-700 mb-1">
              URL Gambar Thumbnail <span class="text-red-500">*</span>
            </label>
            <input
              id="thumbnail_url"
              name="thumbnail_url"
              type="url"
              required
              placeholder="https://imgur.com/your-image.png"
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
            />
          </div>

          <div class="flex items-center gap-3">
            <Button size="sm" variant="accent" type="submit" id="submit-btn">
              Submit Produk
            </Button>
            <Button isLink size="sm" variant="muted" href="/">
              Batal
            </Button>
          </div>
        </form>
      </Wrapper>
    </Wrapper>
  </section>
</BaseLayout>

<script is:inline>
  (() => {
    // Tagline character counter
    const tagline = document.getElementById('tagline');
    const counter = document.getElementById('tagline-count');
    if (tagline && counter) {
      tagline.addEventListener('input', () => {
        counter.textContent = tagline.value.length;
      });
    }

    // Show error/message from URL params
    const params = new URLSearchParams(window.location.search);
    const error = params.get('error');
    const message = params.get('message');
    const msgContainer = document.getElementById('submit-messages');

    if (error && msgContainer) {
      msgContainer.innerHTML = `<div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">${error}</div>`;
    }
    if (message && msgContainer) {
      msgContainer.innerHTML = `<div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">${message}</div>`;
    }

    // Form submitting indicator
    const form = document.getElementById('submit-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        const btn = document.getElementById('submit-btn');
        if (btn) {
          btn.setAttribute('disabled', 'true');
          btn.textContent = 'Submitting...';
        }
      });
    }
  })();
</script>
