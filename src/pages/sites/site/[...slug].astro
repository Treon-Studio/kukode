---
// Get posts from "sites" collection, or Turso database

import { getCollection, render } from 'astro:content';
import { Effect } from 'effect';
import SitesLayout from '@/layouts/SitesLayout.astro';
import DisqusClone from '@/domain/comments/components/DisqusClone.jsx';
import { recordEventProgram } from '@/domain/analytics';
import { ISiteRepository } from '@/domain/site';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';

const { slug } = Astro.params;
const user = (Astro.locals as any).user;
const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// Build i18n label bag for the React comment thread.
// `client:only="react"` is required (uses DOM-only APIs — contentEditable,
// document.execCommand, DOMParser) so we hand it fully-resolved strings.
const commentLabels = {
  countTitle: (n: number) => t('comments.countTitle', { count: n }),
  composerPlaceholder: t('comments.composerPlaceholder'),
  send: t('comments.send'),
  reply: t('comments.reply'),
  replyPlaceholder: (name: string) =>
    t('comments.replyPlaceholder', { name }),
  upvote: t('comments.upvote'),
  report: t('comments.report'),
  share: t('comments.share'),
  hideReplies: t('comments.hideReplies'),
  showReplies: t('comments.showReplies'),
  showMore: t('comments.showMore'),
  maker: t('comments.maker'),
  timeAgo: (ms: number) => {
    const diff = Math.floor(ms / 1000);
    if (diff < 60) return t('comments.timeAgo.justNow');
    if (diff < 3600) return t('comments.timeAgo.minutes', { n: Math.floor(diff / 60) });
    if (diff < 86400) return t('comments.timeAgo.hours', { n: Math.floor(diff / 3600) });
    return t('comments.timeAgo.days', { n: Math.floor(diff / 86400) });
  },
};

if (!slug) {
  return Astro.redirect('/404');
}

let frontmatter: any = null;
let isDynamic = false;
let ContentComp: any = null;
let voteCount = 0;
let voted = false;
let siteId = '';

// 1. Check static collection first
const sites = await getCollection('sites');
const staticPage = sites.find((page) => page.id === slug);

if (staticPage) {
  const { Content } = await render(staticPage);
  ContentComp = Content;
  frontmatter = { ...staticPage.data, id: staticPage.id };
} else {
  // 2. If not found, check Turso DB
  let dbSite = null;
  try {
    const appRuntime = createAppRuntime(Astro.locals);
    dbSite = await appRuntime.runPromise(Effect.gen(function* () {
      const repo = yield* ISiteRepository;
      return yield* repo.getSiteDetailsWithVotes(slug, user?.id);
    }));
  } catch (e) {
    console.error('[Site page] DB lookup failed:', e);
  }

  if (!dbSite) {
    return Astro.redirect('/404');
  }

  isDynamic = true;
  siteId = dbSite.id;
  voteCount = dbSite.voteCount;
  voted = dbSite.voted;

  // 3. Record view and update view count asynchronously
  const ip =
    Astro.request.headers.get('cf-connecting-ip') ||
    Astro.request.headers.get('x-real-ip') ||
    Astro.request.headers.get('x-forwarded-for')?.split(',')[0].trim() ||
    '127.0.0.1';
  const country = Astro.request.headers.get('cf-ipcountry') || 'Unknown';
  const city = Astro.request.headers.get('cf-ipcity') || 'Unknown';
  const referrer = Astro.request.headers.get('referer') || 'direct';

  appRuntime.runPromise(
    recordEventProgram({
      siteId: dbSite.id,
      eventType: 'view',
      referrer,
      ip,
      userId: user?.id,
      country,
      city,
    })
  ).catch((err) => console.error('[Analytics] Failed to track view:', err));

  appRuntime.runPromise(Effect.gen(function* () {
    const repo = yield* ISiteRepository;
    yield* repo.incrementSiteViews(dbSite.id);
  })).catch();

  // Map dynamic data to SitesLayout expected frontmatter
  frontmatter = {
    id: dbSite.id,
    title: dbSite.title,
    description: dbSite.description,
    live: dbSite.live_url,
    thumbnail: {
      url: dbSite.thumbnail_url,
      alt: dbSite.title,
    },
    details: [
      { label: 'Maker', value: `@${dbSite.maker_username || 'unknown'}` },
      { label: 'Tagline', value: dbSite.tagline },
      { label: 'Views', value: `${(dbSite.views_count || 0) + 1} views` },
      {
        label: 'Submitted',
        value: dbSite.created_at
          ? new Date(dbSite.created_at).toLocaleDateString('id-ID')
          : 'Unknown',
      },
    ],
  };
}
---

<SitesLayout
  frontmatter={frontmatter}
  isDynamic={isDynamic}
  voteCount={voteCount}
  voted={voted}
  siteId={siteId}
>
  {ContentComp && <ContentComp />}

  {/* Comment thread — React island (client-only because it uses contentEditable + document APIs) */}
  <DisqusClone
    client:only="react"
    labels={commentLabels}
  />
</SitesLayout>
