---
import Button from '@/components/fundations/elements/Button.astro';
import PasswordInput from '@/components/fundations/elements/PasswordInput.astro';
import Text from '@/components/fundations/elements/Text.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<!-- Auth Modal Container -->
<div id="auth-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-base-950/40 backdrop-blur-xs transition-opacity duration-300" role="dialog" aria-modal="true" aria-labelledby="auth-modal-title">
  <div id="auth-modal-box" class="bg-white border border-base-200 rounded-3xl p-8 w-full max-w-md mx-4 shadow-2xl transform scale-95 opacity-0 transition-all duration-300 relative flex flex-col max-h-[90vh] overflow-y-auto scrollbar-hide">
    
    <!-- Close button -->
    <button
      type="button"
      id="auth-modal-close"
      class="absolute top-4 right-4 flex items-center justify-center size-8 rounded-full bg-base-100 hover:bg-base-200 text-base-500 hover:text-base-800 transition-colors focus:outline-none cursor-pointer"
      aria-label="Close modal"
    >
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Modal Content -->
    <div class="flex-1 w-full flex flex-col mt-4">
      <div class="text-center mb-6">
        <Text
          tag="h2"
          id="auth-modal-title"
          class="text-2xl font-bold text-base-900 font-sans"
        >
          Sign Up
        </Text>
        <p id="auth-modal-subtitle" class="text-xs text-base-500 mt-2.5 leading-relaxed font-sans px-4">
          By continuing, you agree to our <a href="/legal/terms" class="text-accent-600 hover:underline">User Agreement</a> and acknowledge that you understand the <a href="/legal/privacy" class="text-accent-600 hover:underline">Privacy Policy</a>.
        </p>
      </div>

      <!-- Error Alert -->
      <div id="auth-modal-error" class="hidden mb-4 rounded-xl bg-red-50 border border-red-200 px-4 py-3 text-xs text-red-800 font-sans" role="alert"></div>

      <!-- OAuth & Passkey Buttons -->
      <div class="flex flex-col gap-2.5 mb-6">
        <!-- Google login -->
        <a
          href="/api/auth/google/login"
          class="w-full flex items-center justify-center gap-3 px-5 py-2.5 text-xs font-semibold rounded-full border border-base-200 bg-white hover:bg-base-50 text-base-800 transition duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500 shadow-xs"
        >
          <svg class="size-4 shrink-0" viewBox="0 0 24 24" width="24" height="24" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          <span id="google-btn-text">Continue with Google</span>
        </a>

        <!-- Passkey login -->
        <button
          type="button"
          id="auth-modal-passkey-btn"
          class="w-full flex items-center justify-center gap-3 px-5 py-2.5 text-xs font-semibold rounded-full border border-base-200 bg-white hover:bg-base-50 text-base-800 transition duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500 shadow-xs cursor-pointer"
        >
          <span class="text-sm shrink-0">🔑</span>
          <span id="passkey-btn-text">Continue with Passkey</span>
        </button>
      </div>

      <!-- Divider -->
      <div class="relative flex py-2 items-center mb-6">
        <div class="flex-grow border-t border-base-200"></div>
        <span class="flex-shrink mx-4 text-[10px] font-bold text-base-400 tracking-widest uppercase">OR</span>
        <div class="flex-grow border-t border-base-200"></div>
      </div>

      <!-- Native Auth Form -->
      <form id="auth-modal-form" class="space-y-4 font-sans">
        <!-- Email Input (Always Shown) -->
        <div class="w-full">
          <div class="flex items-baseline justify-between mb-1">
            <label for="modal-email" class="text-xs font-semibold text-base-500">
              Email <span class="text-red-500">*</span>
            </label>
          </div>
          <div class="relative">
            <input
              id="modal-email"
              name="email"
              type="email"
              required
              placeholder="e.g. user@example.com"
              class="block w-full px-4 py-2.5 text-xs leading-tight bg-base-50 hover:bg-white focus:bg-white border border-base-200 focus:border-accent-500 rounded-xl text-base-700 transition duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
              inputmode="email"
            />
          </div>
        </div>

        <!-- Signup Only: Full Name -->
        <div class="w-full auth-signup-only">
          <div class="flex items-baseline justify-between mb-1">
            <label for="modal-fullname" class="text-xs font-semibold text-base-500">
              Full Name
            </label>
          </div>
          <div class="relative">
            <input
              id="modal-fullname"
              name="full_name"
              type="text"
              placeholder="e.g. Jane Doe"
              class="block w-full px-4 py-2.5 text-xs leading-tight bg-base-50 hover:bg-white focus:bg-white border border-base-200 focus:border-accent-500 rounded-xl text-base-700 transition duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
            />
          </div>
        </div>

        <!-- Signup Only: Username -->
        <div class="w-full auth-signup-only">
          <div class="flex items-baseline justify-between mb-1">
            <label for="modal-username" class="text-xs font-semibold text-base-500">
              Username <span class="text-red-500">*</span>
            </label>
          </div>
          <div class="relative">
            <input
              id="modal-username"
              name="username"
              type="text"
              placeholder="e.g. janedoe"
              class="block w-full px-4 py-2.5 text-xs leading-tight bg-base-50 hover:bg-white focus:bg-white border border-base-200 focus:border-accent-500 rounded-xl text-base-700 transition duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500/20"
            />
          </div>
          <p class="text-[9px] text-base-400 mt-1" id="modal-username-helper"></p>
        </div>

        <!-- Password (Always Shown) -->
        <PasswordInput
          id="modal-password"
          name="password"
          label="Password"
          class="auth-field-password rounded-xl"
        />

        <!-- Signup Only: Confirm Password -->
        <PasswordInput
          id="modal-confirm-password"
          name="confirm_password"
          label="Confirm Password"
          class="auth-signup-only auth-field-password rounded-xl"
        />

        <!-- Signin Only: Remember me -->
        <div class="flex items-center auth-signin-only pt-1">
          <input
            type="checkbox"
            id="modal-remember"
            name="remember"
            class="rounded border-base-300 text-accent-600 focus:ring-accent-500 focus:ring-offset-2 focus:ring-2 size-4 cursor-pointer"
          />
          <label
            for="modal-remember"
            class="ml-2 text-xs font-medium text-base-500 cursor-pointer"
          >
            Remember me for 30 days
          </label>
        </div>

        <!-- Submit Button -->
        <div class="pt-3">
          <button
            type="submit"
            id="auth-modal-submit"
            class="w-full flex items-center justify-center px-5 py-3 text-xs font-bold rounded-full bg-accent-600 hover:bg-accent-700 text-white transition duration-200 cursor-pointer shadow-sm disabled:opacity-50"
          >
            Continue
          </button>
        </div>
      </form>

      <!-- Footer Switcher -->
      <div class="text-center mt-6 text-xs text-base-500 font-sans">
        <span id="auth-modal-footer-text">Already a maker?</span>
        <button
          type="button"
          id="auth-modal-toggle-mode"
          class="font-semibold text-accent-600 hover:text-accent-700 ml-1 hover:underline cursor-pointer focus:outline-none"
        >
          Log In
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import 'webauthn-polyfills';

  let currentMode = 'signup'; // 'signin' | 'signup'
  let isUsernameEdited = false;
  let autofillAbortController = new AbortController();

  const lang = document.documentElement.lang || 'en';

  // Translations object
  const translations = {
    en: {
      signinTitle: 'Sign In',
      signupTitle: 'Sign Up',
      googleSignin: 'Continue with Google',
      googleSignup: 'Continue with Google',
      passkeySignin: 'Continue with Passkey',
      passkeySignup: 'Continue with Passkey',
      submitSignin: 'Log In',
      submitSignup: 'Continue',
      footerSignin: 'Already a maker?',
      footerSignup: 'New to Kukode?',
      toggleSignin: 'Log In',
      toggleSignup: 'Sign Up',
      emailPlaceholder: 'e.g. user@example.com',
      usernameHelperSuggested: 'Suggested username (auto-generated).',
      usernameHelperCustom: 'Custom username.',
      passwordsMismatch: 'Passwords do not match.',
      passkeyChecking: 'Checking authenticator...',
      passkeyVerifying: 'Verifying...',
      authFailed: 'Authentication failed.',
      passkeyFailed: 'Passkey verification failed.',
    },
    id: {
      signinTitle: 'Masuk',
      signupTitle: 'Daftar',
      googleSignin: 'Lanjutkan dengan Google',
      googleSignup: 'Lanjutkan dengan Google',
      passkeySignin: 'Lanjutkan dengan Passkey',
      passkeySignup: 'Lanjutkan dengan Passkey',
      submitSignin: 'Masuk',
      submitSignup: 'Lanjutkan',
      footerSignin: 'Sudah punya akun?',
      footerSignup: 'Baru di Kukode?',
      toggleSignin: 'Masuk',
      toggleSignup: 'Daftar',
      emailPlaceholder: 'misal: user@example.com',
      usernameHelperSuggested: 'Saran username (dibuat otomatis).',
      usernameHelperCustom: 'Username pilihan Anda.',
      passwordsMismatch: 'Kata sandi dan konfirmasi kata sandi tidak cocok.',
      passkeyChecking: 'Memeriksa autentikator...',
      passkeyVerifying: 'Memverifikasi...',
      authFailed: 'Autentikasi gagal.',
      passkeyFailed: 'Verifikasi Passkey gagal.',
    }
  };

  const t = (key: string): string => {
    const dict = translations[lang as 'en' | 'id'] || translations.en;
    return (dict as any)[key] || key;
  };

  // DOM Elements
  const modal = document.getElementById('auth-modal');
  const modalBox = document.getElementById('auth-modal-box');
  const closeBtn = document.getElementById('auth-modal-close');
  const form = document.getElementById('auth-modal-form') as HTMLFormElement;
  const titleEl = document.getElementById('auth-modal-title');
  const subtitleEl = document.getElementById('auth-modal-subtitle');
  const errorEl = document.getElementById('auth-modal-error');
  const submitBtn = document.getElementById('auth-modal-submit');
  const toggleBtn = document.getElementById('auth-modal-toggle-mode');
  const footerTextEl = document.getElementById('auth-modal-footer-text');
  
  const googleBtnText = document.getElementById('google-btn-text');
  const passkeyBtn = document.getElementById('auth-modal-passkey-btn');
  const passkeyBtnText = document.getElementById('passkey-btn-text');

  const emailInput = document.getElementById('modal-email') as HTMLInputElement;
  const usernameInput = document.getElementById('modal-username') as HTMLInputElement;
  const usernameHelper = document.getElementById('modal-username-helper');
  const passwordInput = document.getElementById('modal-password') as HTMLInputElement;
  const confirmPasswordInput = document.getElementById('modal-confirm-password') as HTMLInputElement;

  // Open Modal Function
  function openAuthModal(mode: 'signin' | 'signup') {
    if (!modal || !modalBox) return;
    setMode(mode);
    
    // Clear any previous error
    showError(null);

    modal.classList.remove('hidden');
    modal.classList.add('flex');
    
    // Trigger transition
    requestAnimationFrame(() => {
      modalBox.classList.remove('scale-95', 'opacity-0');
      modalBox.classList.add('scale-100', 'opacity-100');
    });

    // Autofill initialization for passkey login
    if (mode === 'signin') {
      initializeConditionalAutofill();
    }
  }

  // Close Modal Function
  function closeAuthModal() {
    if (!modal || !modalBox) return;
    autofillAbortController.abort();
    autofillAbortController = new AbortController();

    modalBox.classList.remove('scale-100', 'opacity-100');
    modalBox.classList.add('scale-95', 'opacity-0');
    setTimeout(() => {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    }, 300);
  }

  // Toggle mode elements
  function setMode(mode: 'signin' | 'signup') {
    currentMode = mode;
    
    if (mode === 'signin') {
      // Title & Subtitle
      if (titleEl) titleEl.textContent = t('signinTitle');
      if (subtitleEl) subtitleEl.classList.add('hidden'); // Less warning text on sign-in
      
      // Buttons
      if (googleBtnText) googleBtnText.textContent = t('googleSignin');
      if (passkeyBtnText) passkeyBtnText.textContent = t('passkeySignin');
      if (submitBtn) submitBtn.textContent = t('submitSignin');
      
      // Footer switcher
      if (footerTextEl) footerTextEl.textContent = t('footerSignup');
      if (toggleBtn) toggleBtn.textContent = t('toggleSignin');

      // Hide signup-only inputs
      document.querySelectorAll('.auth-signup-only').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('.auth-signin-only').forEach(el => el.classList.remove('hidden'));

      // Make fields not required
      if (usernameInput) usernameInput.required = false;
      if (confirmPasswordInput) confirmPasswordInput.required = false;
    } else {
      // Title & Subtitle
      if (titleEl) titleEl.textContent = t('signupTitle');
      if (subtitleEl) subtitleEl.classList.remove('hidden');

      // Buttons
      if (googleBtnText) googleBtnText.textContent = t('googleSignup');
      if (passkeyBtnText) passkeyBtnText.textContent = t('passkeySignup');
      if (submitBtn) submitBtn.textContent = t('submitSignup');

      // Footer switcher
      if (footerTextEl) footerTextEl.textContent = t('footerSignin');
      if (toggleBtn) toggleBtn.textContent = t('toggleSignup');

      // Show signup-only inputs
      document.querySelectorAll('.auth-signup-only').forEach(el => el.classList.remove('hidden'));
      document.querySelectorAll('.auth-signin-only').forEach(el => el.classList.add('hidden'));

      // Make fields required
      if (usernameInput) usernameInput.required = true;
      if (confirmPasswordInput) confirmPasswordInput.required = true;

      // Suggest initial username if empty and not edited
      if (usernameInput && !usernameInput.value && !isUsernameEdited) {
        generateRandomUsername();
      }
    }
  }

  function showError(msg: string | null) {
    if (!errorEl) return;
    if (msg) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    } else {
      errorEl.classList.add('hidden');
    }
  }

  function generateRandomUsername() {
    if (!usernameInput || isUsernameEdited) return;
    const randomSuffix = Math.floor(1000 + Math.random() * 9000);
    usernameInput.value = `user_${randomSuffix}`;
    if (usernameHelper) {
      usernameHelper.textContent = t('usernameHelperSuggested');
      usernameHelper.className = 'text-[9px] text-base-400 mt-1';
    }
  }

  // Trigger handlers
  function setupTriggers() {
    document.querySelectorAll('[data-auth-trigger]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const mode = el.getAttribute('data-auth-trigger') as 'signin' | 'signup';
        openAuthModal(mode || 'signup');
      });
    });
  }

  // Passkey login conditional UI
  async function initializeConditionalAutofill() {
    try {
      const capabilities = await PublicKeyCredential.getClientCapabilities();
      if (capabilities.conditionalGet === true) {
        const optionsRes = await fetch('/api/auth/passkey/login-options');
        if (!optionsRes.ok) return;
        const options = await optionsRes.json();

        const publicKey = PublicKeyCredential.parseRequestOptionsFromJSON(options);
        const credential = await navigator.credentials.get({
          publicKey,
          signal: autofillAbortController.signal,
          mediation: 'conditional',
        });

        if (!credential) return;

        const verifyRes = await fetch('/api/auth/passkey/login-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify((credential as any).toJSON()),
        });

        if (verifyRes.ok) {
          window.location.href = '/dashboard';
        } else {
          const data = await verifyRes.json();
          showError(data.error || t('authFailed'));
        }
      }
    } catch (err: any) {
      if (['NotAllowedError', 'AbortError'].includes(err.name)) {
        return;
      }
      console.error('Passkey autofill failed:', err);
    }
  }

  async function triggerPasskeyAuth() {
    if (!passkeyBtn) return;
    autofillAbortController.abort();
    autofillAbortController = new AbortController();

    (passkeyBtn as HTMLButtonElement).disabled = true;
    const originalText = passkeyBtnText?.textContent;
    if (passkeyBtnText) passkeyBtnText.textContent = t('passkeyChecking');

    try {
      const optionsRes = await fetch('/api/auth/passkey/login-options');
      if (!optionsRes.ok) {
        const errData = await optionsRes.json();
        throw new Error(errData.error || 'Failed to fetch options');
      }
      const options = await optionsRes.json();

      const publicKey = PublicKeyCredential.parseRequestOptionsFromJSON(options);
      const credential = await navigator.credentials.get({
        publicKey,
        signal: autofillAbortController.signal,
      });

      if (!credential) {
        throw new Error(t('passkeyFailed'));
      }

      if (passkeyBtnText) passkeyBtnText.textContent = t('passkeyVerifying');

      const verifyRes = await fetch('/api/auth/passkey/login-verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify((credential as any).toJSON()),
      });

      if (!verifyRes.ok) {
        const errData = await verifyRes.json();
        throw new Error(errData.error || 'Verification failed');
      }

      window.location.href = '/dashboard';
    } catch (err: any) {
      console.error(err);
      showError(err.message || t('passkeyFailed'));
      (passkeyBtn as HTMLButtonElement).disabled = false;
      if (passkeyBtnText && originalText) passkeyBtnText.textContent = originalText;
      initializeConditionalAutofill();
    }
  }

  // Setup DOM Event Listeners
  document.addEventListener('DOMContentLoaded', () => {
    setupTriggers();

    if (closeBtn) closeBtn.addEventListener('click', closeAuthModal);
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeAuthModal();
      });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeAuthModal();
      }
    });

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        setMode(currentMode === 'signin' ? 'signup' : 'signin');
      });
    }

    // Username Sync Script
    if (emailInput && usernameInput) {
      emailInput.addEventListener('input', () => {
        if (isUsernameEdited || currentMode === 'signin') return;

        const emailVal = emailInput.value || '';
        const atIndex = emailVal.indexOf('@');
        let suggested = '';

        if (atIndex > 0) {
          suggested = emailVal.slice(0, atIndex).toLowerCase();
        } else {
          suggested = emailVal.toLowerCase();
        }

        suggested = suggested.replace(/[^a-z0-9_.-]/g, '');

        if (suggested) {
          usernameInput.value = suggested;
        }
      });
    }

    if (usernameInput) {
      usernameInput.addEventListener('input', () => {
        isUsernameEdited = true;
        if (usernameHelper) {
          usernameHelper.textContent = t('usernameHelperCustom');
          usernameHelper.className = 'text-[9px] text-accent-600 font-semibold mt-1';
        }
      });
    }

    if (passkeyBtn) {
      passkeyBtn.addEventListener('click', triggerPasskeyAuth);
    }

    // Handle Form Submit (Native Authentication via fetch)
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        showError(null);

        const email = emailInput.value;
        const password = passwordInput.value;

        if (currentMode === 'signup') {
          const confirmPassword = confirmPasswordInput.value;
          if (password !== confirmPassword) {
            showError(t('passwordsMismatch'));
            return;
          }
        }

        // Disable submit button during fetch
        if (submitBtn) {
          (submitBtn as HTMLButtonElement).disabled = true;
          submitBtn.textContent = currentMode === 'signin' ? t('passkeyVerifying') : 'Registering...';
        }

        const formData = new FormData(form);
        const endpoint = currentMode === 'signin' ? '/api/auth/signin' : '/api/auth/signup';

        try {
          const res = await fetch(endpoint, {
            method: 'POST',
            body: formData,
            headers: {
              // Instruct API endpoint to redirect on success or return error status
              'Accept': 'application/json',
            }
          });

          // Check if response is redirect
          if (res.redirected) {
            window.location.href = res.url;
            return;
          }

          const data = await res.json();
          
          if (res.ok) {
            window.location.href = '/dashboard';
          } else {
            showError(data.error || 'Authentication failed');
          }
        } catch (err: any) {
          console.error('Auth error:', err);
          showError('An unexpected error occurred. Please try again.');
        } finally {
          if (submitBtn) {
            (submitBtn as HTMLButtonElement).disabled = false;
            submitBtn.textContent = currentMode === 'signin' ? t('submitSignin') : t('submitSignup');
          }
        }
      });
    }
  });

  // Re-run setup on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    setupTriggers();
  });
</script>
