---
import { getCollection } from 'astro:content';
import { Effect } from 'effect';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import SiteCard from '@/domain/site/components/SiteCard.astro';
import SponsorCard from '@/domain/site/components/SponsorCard.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { ISiteRepository } from '@/domain/site';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// 1. Fetch static tools
const staticSites = await getCollection('sites');

// 2. Fetch dynamic tools
const user = (Astro.locals as any).user;

const appRuntime = createAppRuntime(Astro.locals);
const runnable = Effect.gen(function* () {
  const repo = yield* ISiteRepository;
  return yield* repo.getApprovedSitesWithVotes(user?.id);
});

const dynamicSites = await appRuntime.runPromise(runnable);

// Sort dynamic sites by popularity (votes) or recent
const filterTab = Astro.url.searchParams.get('tab') || 'terbaru';

if (filterTab === 'populer') {
  dynamicSites.sort((a, b) => b.voteCount - a.voteCount);
} else {
  // terbaru
  dynamicSites.sort((a, b) => b.createdAt - a.createdAt);
}

// 3. Combine them (Dynamic first, then Static)
const alltools = [...dynamicSites, ...staticSites];

const allTags = [...new Set(alltools.flatMap((post) => post.data.tags || []))];
const sortedTags = allTags.sort((a, b) => a.localeCompare(b));
const initialVisible = 7;
const step = initialVisible;
---

<section data-sites-preview data-step={step} data-initial={initialVisible}>
  <Wrapper variant="standard" class="py-24">
    <div class="flex items-center justify-between mb-8 flex-wrap gap-4">
      {/* Tags Scroll */}
      <div class="relative flex snap-x snap-proximity gap-1 py-2 overflow-x-auto scrollbar-hide flex-1 min-w-0">
        <Button
          isLink
          size="xs"
          variant="muted"
          href="/sites/tags"
          class="capitalize shrink-0"
        >
          {t('sites.allTags')}
        </Button>
        {
          sortedTags.slice(0, 10).map((tag) => (
            <Button
              isLink
              size="xs"
              variant="muted"
              title={tag}
              aria-label={tag}
              href={`/sites/tags/${tag}`}
              class="capitalize shrink-0"
            >
              {tag}
            </Button>
          ))
        }
      </div>

      {/* Filters (Terbaru / Populer) */}
      <div class="flex items-center gap-2 bg-base-50 p-1 rounded-lg shrink-0">
        <a
          href="?tab=terbaru"
          class:list={[
            "px-3 py-1.5 text-xs font-medium rounded-md transition-colors",
            filterTab === 'terbaru' ? "bg-white text-base-900 shadow-sm" : "text-base-500 hover:text-base-900"
          ]}
        >
          {t('sites.terbaru')}
        </a>
        <a
          href="?tab=populer"
          class:list={[
            "px-3 py-1.5 text-xs font-medium rounded-md transition-colors",
            filterTab === 'populer' ? "bg-white text-base-900 shadow-sm" : "text-base-500 hover:text-base-900"
          ]}
        >
          {t('sites.populer')}
        </a>
      </div>
    </div>

    <div
      class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4"
      data-sites-list
    >
      {
        alltools.map((post: any, i) => (
          <>
            <div data-site-card class={i >= initialVisible ? "hidden" : ""}>
              <SiteCard 
                key={`post-${i}`} 
                post={post} 
                siteId={post.isDynamic ? post.id : undefined}
                voteCount={post.voteCount}
                voted={post.voted}
              />
            </div>
            {i === 2 && <SponsorCard key={`sponsor-${i}`} />}
          </>
        ))
      }
    </div>
    {
      alltools.length > initialVisible && (
        <div class="flex justify-center mt-10">
          <Button
            type="button"
            variant="muted"
            size="sm"
            data-sites-more
            class="px-6"
          >
            {t('sites.showMore')}
          </Button>
        </div>
      )
    }
  </Wrapper>
</section>

<script is:inline>
  (() => {
    const section = document.querySelector("[data-sites-preview]");
    if (!section) return;
    const cards = Array.from(section.querySelectorAll("[data-site-card]"));
    const button = section.querySelector("[data-sites-more]");
    const step = parseInt(section.dataset.step || "7", 10);
    let visible = parseInt(section.dataset.initial || "7", 10);

    const update = () => {
      cards.forEach((card, i) => {
        card.classList.toggle("hidden", i >= visible);
      });
      if (button) {
        button.classList.toggle("hidden", visible >= cards.length);
      }
    };

    button?.addEventListener("click", () => {
      visible += step;
      update();
    });

    update();
  })();
</script>
