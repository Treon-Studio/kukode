---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Logo from '@/components/global/Logo.astro';
import UserAvatar from '@/components/global/UserAvatar.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import { NAVIGATION_LINKS } from '@/lib/constants';
import MobileNav from './MobileNav.astro';

// Get user and profile from middleware (Astro.locals)
const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;
const isLoggedIn = !!user;

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// Centralized navigation links mapped with translation helper
const links = NAVIGATION_LINKS.map((link) => ({
  href: link.href,
  text: t(link.translationKey),
}));
---

<MobileNav />
<nav class="fixed w-full top-0 z-20 backdrop-blur-md bg-white/90 border-b border-base-200 py-2.5 hidden md:block">
  <Wrapper variant="standard">
    <div class="flex items-center justify-between w-full gap-4 lg:gap-6">
      
      {/* Left: Logo & Dropdown */}
      <div class="flex items-center gap-2 shrink-0">
        {/* More Links Dropdown */}
        <div class="relative mr-2" data-nav-dropdown>
          <button
             type="button"
             class="flex items-center justify-center size-9 rounded-full hover:bg-base-100 transition-colors focus:outline-none"
             data-nav-dropdown-toggle
             aria-expanded="false"
             aria-label="More options"
          >
             <svg class="size-5 text-base-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h.01M12 12h.01M19 12h.01M6 12a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0zm7 0a1 1 0 11-2 0 1 1 0 012 0z" />
             </svg>
          </button>
          <div
             class="hidden absolute left-0 mt-2 w-48 rounded-lg bg-white shadow-lg ring-1 ring-base-200 py-1 z-50 focus:outline-none"
             data-nav-dropdown-menu
          >
             {links.map((link) => (
                <a href={link.href} class="block px-4 py-2 text-sm font-medium text-base-700 hover:bg-base-50 transition-colors">
                  {link.text}
                </a>
             ))}
             {/* Include Language Switcher inside dropdown for simplicity */}
             <div class="border-t border-base-100 my-1"></div>
             <div class="px-4 py-2">
               <p class="text-[10px] uppercase font-bold tracking-wider text-base-400 mb-2">Language</p>
               <a href="?lang=en" class={`block text-xs py-1 transition-colors hover:text-accent-600 ${lang === 'en' ? 'font-semibold text-accent-600' : 'text-base-600'}`}>English</a>
               <a href="?lang=id" class={`block text-xs py-1 transition-colors hover:text-accent-600 ${lang === 'id' ? 'font-semibold text-accent-600' : 'text-base-600'}`}>Bahasa Indonesia</a>
             </div>
          </div>
        </div>

        <a href="/" class="shrink-0 focus:outline-none group" aria-label="Go to homepage">
          <Logo class="text-base-900 h-8 w-auto" />
        </a>
      </div>

      {/* Center: Large Pill Search Bar */}
      <div class="flex-1 max-w-2xl px-2 lg:px-8">
        <button
          id="search-button"
          type="button"
          class="w-full flex items-center gap-3 px-4 py-2.5 bg-base-50 hover:bg-white border border-base-200 hover:border-accent-400 rounded-full text-sm text-base-500 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent-500/30 group"
          aria-label="Search"
        >
          <svg class="size-5 text-base-500 group-hover:text-base-700 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="text-base-400 truncate text-left w-full group-hover:text-base-500 transition-colors">Search in Kukode</span>
        </button>
      </div>

      {/* Right: Auth / Profile */}
      <div class="flex items-center gap-3 shrink-0">
        {isLoggedIn ? (
          <div class="relative" data-user-dropdown>
            <button
              type="button"
              class="flex items-center gap-2 shrink-0 rounded-full focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 hover:opacity-90 transition-opacity"
              data-user-dropdown-toggle
              aria-expanded="false"
              aria-haspopup="menu"
              aria-label={profile?.username || user.email || 'User menu'}
            >
              <UserAvatar
                avatarUrl={profile?.avatar_url}
                username={profile?.username}
                email={user.email}
                class="size-9 shadow-sm"
              />
            </button>
            <div
              class="hidden absolute right-0 mt-2 w-48 rounded-lg bg-white shadow-lg ring-1 ring-base-200 py-1 z-50 focus:outline-none"
              data-user-dropdown-menu
            >
              <div class="px-4 py-3 border-b border-base-100">
                <p class="text-sm font-medium text-base-900 truncate">
                  {profile?.full_name || profile?.username || 'User'}
                </p>
                <p class="text-xs text-base-500 truncate mt-0.5">{user.email}</p>
              </div>
              <a href="/dashboard" class="block px-4 py-2 text-sm text-base-700 hover:bg-base-50 transition-colors">{t('nav.dashboard')}</a>
              <a href="/dashboard/settings" class="block px-4 py-2 text-sm text-base-700 hover:bg-base-50 transition-colors">{t('nav.settings')}</a>
              {profile?.role === 'admin' && (
                <a href="/admin" class="block px-4 py-2 text-sm text-base-700 hover:bg-base-50 transition-colors">{t('nav.admin')}</a>
              )}
              <form method="POST" action="/api/auth/signout" class="border-t border-base-100 mt-1">
                <button type="submit" class="w-full text-left px-4 py-2.5 text-sm font-medium text-red-600 hover:bg-red-50 transition-colors">
                  {t('nav.signout')}
                </button>
              </form>
            </div>
          </div>
        ) : (
          <div class="flex items-center gap-2">
            <a href="/signup" data-auth-trigger="signup" class="px-5 py-2 rounded-full text-sm font-bold text-base-700 bg-base-100 hover:bg-base-200 transition-colors whitespace-nowrap border border-transparent">
              {t('nav.signup')}
            </a>
            <a href="/signin" data-auth-trigger="signin" class="px-5 py-2 rounded-full text-sm font-bold text-white bg-accent-600 hover:bg-accent-700 transition-colors whitespace-nowrap border border-transparent">
              {t('nav.signin')}
            </a>
          </div>
        )}
      </div>
    </div>
  </Wrapper>
</nav>

<script is:inline>
  (() => {
    function setupDropdown(containerSelector, toggleSelector, menuSelector) {
      const container = document.querySelector(containerSelector);
      if (!container) return;
      const toggle = container.querySelector(toggleSelector);
      const menu = container.querySelector(menuSelector);
      if (toggle && menu) {
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !menu.classList.contains('hidden');
          
          // Close all other menus first
          document.querySelectorAll('[data-nav-dropdown-menu], [data-user-dropdown-menu]').forEach(el => el.classList.add('hidden'));
          document.querySelectorAll('[data-nav-dropdown-toggle], [data-user-dropdown-toggle]').forEach(el => el.setAttribute('aria-expanded', 'false'));
          
          if (!isOpen) {
            menu.classList.remove('hidden');
            toggle.setAttribute('aria-expanded', 'true');
          }
        });
      }
    }

    setupDropdown('[data-user-dropdown]', '[data-user-dropdown-toggle]', '[data-user-dropdown-menu]');
    setupDropdown('[data-nav-dropdown]', '[data-nav-dropdown-toggle]', '[data-nav-dropdown-menu]');

    // Global click listener to close dropdowns
    document.addEventListener('click', () => {
      document.querySelectorAll('[data-nav-dropdown-menu], [data-user-dropdown-menu]').forEach(el => el.classList.add('hidden'));
      document.querySelectorAll('[data-nav-dropdown-toggle], [data-user-dropdown-toggle]').forEach(el => el.setAttribute('aria-expanded', 'false'));
    });
  })();
</script>
