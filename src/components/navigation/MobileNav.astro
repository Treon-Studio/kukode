---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Burger from '@/components/fundations/icons/Burger.astro';
import Logo from '@/components/global/Logo.astro';
import UserAvatar from '@/components/global/UserAvatar.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import { NAVIGATION_LINKS } from '@/lib/constants';

// Get user and profile from middleware
const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;
const isLoggedIn = !!user;

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// Centralized navigation links mapped with translation helper
const links = NAVIGATION_LINKS.map((link) => ({
  href: link.href,
  text: t(link.translationKey),
}));
---

<nav class="fixed inset-x-0 top-0 z-40 backdrop-blur-md bg-white/80 border-b border-base-100 md:hidden">
  <Wrapper variant="standard" class="py-3">
    <div class="flex items-center gap-3">
      <Button
        iconOnly
        size="xs"
        variant="default"
        type="button"
        data-mobile-nav-toggle
        aria-expanded="false"
        aria-label="Open menu"
      >
        <Burger slot="icon" class="size-4" />
      </Button>
      <a href="/" aria-label="Go to homepage" class="group focus:outline-none">
        <Logo class="text-base-900" />
      </a>
    </div>
  </Wrapper>
  <div class="hidden md:hidden bg-white/95 border-b border-base-100 backdrop-blur-md" data-mobile-nav-panel>
    <Wrapper variant="standard" class="py-4">
      <div class="flex flex-col">
        {
          links.map((link) => (
            <a
              class="text-base-900 text-lg font-medium py-1 border-b border-base-100 last:border-b-0"
              href={link.href}
            >
              {link.text}
            </a>
          ))
        }
      </div>

      <!-- Language Selector -->
      <div class="mt-6 pt-6 border-t border-base-100 flex items-center justify-between">
        <span class="text-xs font-semibold text-base-500 uppercase tracking-wider">Language / Bahasa</span>
        <div class="flex gap-2">
          <a
            href="?lang=en"
            class={`px-3 py-1.5 rounded text-xs font-semibold border ${lang === 'en' ? 'bg-base-900 text-white border-base-900' : 'bg-white text-base-600 border-base-200'}`}
          >
            EN
          </a>
          <a
            href="?lang=id"
            class={`px-3 py-1.5 rounded text-xs font-semibold border ${lang === 'id' ? 'bg-base-900 text-white border-base-900' : 'bg-white text-base-600 border-base-200'}`}
          >
            ID
          </a>
        </div>
      </div>

      <div class="mt-8 flex items-center gap-2">
        {isLoggedIn ? (
          <>
            <div class="flex items-center gap-3 flex-1 min-w-0">
              <UserAvatar
                avatarUrl={profile?.avatar_url}
                username={profile?.username}
                email={user.email}
                class="size-8 shrink-0"
              />
              <span class="text-sm font-medium text-base-900 truncate">
                {profile?.full_name || profile?.username || 'User'}
              </span>
            </div>
            <Button isLink size="xs" variant="muted" href="/dashboard" class="shrink-0">
              {t('nav.dashboard')}
            </Button>
            <form method="POST" action="/api/auth/signout">
              <Button size="xs" variant="default" type="submit" class="shrink-0">
                {t('nav.signout')}
              </Button>
            </form>
          </>
        ) : (
          <>
            <Button isLink size="xs" variant="muted" href="/signin" data-auth-trigger="signin" class="shrink-0"
              >{t('nav.signin')}</Button
            >
            <Button
              isLink
              size="xs"
              variant="default"
              href="/signup"
              data-auth-trigger="signup"
              class="shrink-0">{t('nav.signup')}</Button
            >
          </>
        )}
      </div>
    </Wrapper>
  </div>
</nav>

<script is:inline>
  (() => {
    const toggle = document.querySelector("[data-mobile-nav-toggle]");
    const panel = document.querySelector("[data-mobile-nav-panel]");
    if (!toggle || !panel) return;
    const close = () => {
      panel.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    };
    const open = () => {
      panel.classList.remove("hidden");
      toggle.setAttribute("aria-expanded", "true");
    };
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen) close();
      else open();
    });
    document.addEventListener("click", (e) => {
      if (!panel.contains(e.target) && !toggle.contains(e.target)) {
        close();
      }
    });
    panel.querySelectorAll("[data-auth-trigger]").forEach((el) => {
      el.addEventListener("click", () => {
        close();
      });
    });
  })();
</script>
