---
import { AstroSeo } from '@lexingtonthemes/seo';

import { APP_CONFIG } from '@/lib/constants';

const { title, description, image, url } = Astro.props;

const defaultTitle = 'Kukode';
const defaultDesc = 'Kukode - Platform pengembangan web modern';
const defaultImage = `${APP_CONFIG.BASE_URL}/og-image.jpg`;
const defaultUrl = `${APP_CONFIG.BASE_URL}/`;

const pageTitle = title ? `${title} | Kukode` : defaultTitle;
const pageDesc = description || defaultDesc;
const pageImage = image || defaultImage;
const pageUrl = url || defaultUrl;
---

<AstroSeo
  title={pageTitle}
  description={pageDesc}
  canonical={pageUrl}
  openGraph={{
    url: pageUrl,
    title: pageTitle,
    description: pageDesc,
    images: [
      {
        url: pageImage,
        width: 1200,
        height: 630,
        alt: pageTitle,
        type: "image/jpeg",
      },
    ],
    site_name: "Kukode",
    type: "website",
    locale: "en_US",
  }}
  twitter={{
    handle: "@kukode",
    site: "@kukode",
    cardType: "summary_large_image",
  }}
  additionalMetaTags={[
    {
      name: "robots",
      content: "index, follow",
    },
    {
      name: "googlebot",
      content: "index, follow",
    },
  ]}
/>
