---
import { Effect } from 'effect';
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import { createAppRuntime } from '@/infra/runtime/app.runtime';
import { ISiteRepository } from '@/domain/site';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

// Check if sponsored slots are full (max 3 active)
const appRuntime = createAppRuntime(Astro.locals);
const isSlotFull = await appRuntime.runPromise(Effect.gen(function* () {
  const repo = yield* ISiteRepository;
  return yield* repo.checkSponsoredSlotsFull();
}));

// Data
const packages = [
  {
    name: t('adv.pkg1Name'),
    price: t('adv.pkg1Price'),
    slug: 'article',
    features: [
      {
        label: lang === 'en' ? 'Homepage placement' : 'Penempatan beranda',
        value: lang === 'en' ? '7 days live' : 'Aktif 7 hari',
      },
      {
        label: lang === 'en' ? 'Newsletter highlight' : 'Sorotan newsletter',
        value: lang === 'en' ? '1x weekly send' : '1x kiriman mingguan',
      },
      { label: lang === 'en' ? 'Social push' : 'Promosi media sosial', value: '1x X + LinkedIn' },
    ],
    description: t('adv.pkg1Desc'),
  },
  {
    name: t('adv.pkg2Name'),
    price: t('adv.pkg2Price'),
    slug: 'newsletter',
    features: [
      { label: lang === 'en' ? 'Audience' : 'Audiens', value: '7,800+ subscribers' },
      {
        label: lang === 'en' ? 'Send cadence' : 'Frekuensi pengiriman',
        value: lang === 'en' ? '2 consecutive issues' : '2 edisi berturut-turut',
      },
      {
        label: lang === 'en' ? 'Creative' : 'Kreatif',
        value: lang === 'en' ? 'We help refine copy' : 'Kami bantu edit teks',
      },
    ],
    description: t('adv.pkg2Desc'),
  },
];
---
<BaseLayout
  seoProps={{
    title: 'Advertise',
    description: t('adv.subtitle'),
    url: '/advertise/',
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="text-center max-w-3xl mx-auto text-balance mb-12">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 font-display font-thin text-center"
        >
          {t('adv.title')}
        </Text>
        <Text tag="p" variant="textBase" class="text-base-600 mt-4">
          {t('adv.subtitle')}
        </Text>
      </div>

      {isSlotFull && (
        <div class="mb-12 rounded-lg bg-yellow-50 border border-yellow-200 px-6 py-4 text-center text-sm text-yellow-800 max-w-2xl mx-auto">
          {lang === 'en'
            ? 'Sponsored slots are currently full. Please check back later!'
            : 'Slot promosi saat ini sudah penuh. Silakan coba lagi beberapa saat lagi!'}
        </div>
      )}

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          packages.map((pkg) => (
            <div class="flex flex-col h-full justify-between bg-base-50 rounded-lg p-8 ">
              <div class="flex flex-col gap-8">
                <div class="space-y-3">
                  <Text
                    tag="p"
                    variant="displaySM"
                    class="text-base-900 text-balance font-display font-light"
                  >
                    {pkg.name}
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600">
                    {pkg.description}
                  </Text>
                </div>
                <div>
                  <Text
                    tag="p"
                    variant="displayLG"
                    class="text-base-900 font-display font-light"
                  >
                    {pkg.price}
                  </Text>
                </div>
                <ul class="divide-y divide-base-200 mt-4">
                  {pkg.features.map((item) => (
                    <li class="flex items-center justify-between py-3 text-base-800">
                      <Text tag="span" variant="textBase" class="text-base-800">
                        {item.label}
                      </Text>
                      <Text tag="span" variant="textSM" class="text-base-500">
                        {item.value}
                      </Text>
                    </li>
                  ))}
                </ul>
              </div>
              {isSlotFull ? (
                <Button
                  size="base"
                  variant="muted"
                  disabled={true}
                  class="w-fit mt-8 cursor-not-allowed opacity-50"
                >
                  {lang === 'en' ? 'Slot Full' : 'Slot Penuh'}
                </Button>
              ) : (
                <Button
                  size="base"
                  variant="default"
                  isLink={true}
                  href={`/api/advertise/create-invoice?pkg=${pkg.slug}`}
                  class="w-fit mt-8"
                >
                  {t('pricing.choosePlan')}
                </Button>
              )}
            </div>
          ))
        }
      </div>
    </Wrapper>
  </section>
</BaseLayout>
