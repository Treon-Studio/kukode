---
import Wrapper from '@/components/fundations/containers/Wrapper.astro';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import Faq from '@/components/global/Faq.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);

const plans = [
  {
    name: lang === 'en' ? 'Free' : 'Gratis',
    description:
      lang === 'en'
        ? 'Get limited access to everything.'
        : 'Dapatkan akses terbatas untuk semua fitur.',
    priceStatic: '$0',
    buttonVariant: 'default',
    features: [
      {
        label: lang === 'en' ? 'Bookmarks' : 'Bookmark',
        value: lang === 'en' ? 'Save up to 5 favorites' : 'Simpan hingga 5 favorit',
      },
      {
        label: lang === 'en' ? 'Filters' : 'Filter',
        value:
          lang === 'en' ? 'Basic filters for quick scans' : 'Filter dasar untuk pencarian cepat',
      },
      {
        label: lang === 'en' ? 'Email' : 'Email',
        value: lang === 'en' ? 'Weekly inspiration roundup' : 'Ringkasan inspirasi mingguan',
      },
      {
        label: lang === 'en' ? 'Support' : 'Dukungan',
        value: lang === 'en' ? 'Community help' : 'Bantuan komunitas',
      },
    ],
  },
  {
    name: lang === 'en' ? 'Team' : 'Tim',
    description:
      lang === 'en' ? 'Get full workspace access.' : 'Dapatkan akses penuh ke ruang kerja.',
    priceMonthly: '$9',
    priceAnnual: '$6',
    buttonVariant: 'accent',
    features: [
      {
        label: lang === 'en' ? 'Bookmarks & collections' : 'Bookmark & koleksi',
        value: lang === 'en' ? 'Unlimited for teams' : 'Tanpa batas untuk tim',
      },
      {
        label: lang === 'en' ? 'Filters & tags' : 'Filter & tag',
        value: lang === 'en' ? 'Advanced + saved searches' : 'Pencarian lanjutan + tersimpan',
      },
      {
        label: lang === 'en' ? 'Workspace' : 'Ruang kerja',
        value: lang === 'en' ? 'Shared lists for teammates' : 'Daftar bersama untuk rekan tim',
      },
      { label: lang === 'en' ? 'Exports' : 'Ekspor', value: 'CSV / Notion ready' },
      {
        label: lang === 'en' ? 'Support' : 'Dukungan',
        value: lang === 'en' ? 'Priority replies' : 'Balasan prioritas',
      },
    ],
  },
];
---

<BaseLayout
  seoProps={{
    title: t('pricing.title'),
    description: t('pricing.subtitle'),
    url: '/pricing/',
  }}
>
  <section>
    <Wrapper variant="standard" class="py-24 lg:pt-48">
      <div class="text-balance max-w-3xl mx-auto text-center">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 font-display font-light"
        >
          {t('pricing.title')}
        </Text>
        <Text tag="p" variant="textBase" class="text-base-600 mt-4">
          {t('pricing.subtitle')}
        </Text>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 mt-12">
        {
          plans.map((plan) => (
            <div class="flex flex-col h-full justify-between bg-base-50 rounded-lg p-8 ">
              <div class="flex flex-col gap-8">
                <div class="space-y-3">
                  <Text
                    tag="p"
                    variant="displaySM"
                    class="text-base-900 text-balance font-display font-light"
                  >
                    {plan.name}
                  </Text>
                  <Text tag="p" variant="textSM" class="text-base-600 ">
                    {plan.description}
                  </Text>
                </div>
                <div>
                  {plan.priceStatic ? (
                    <Text
                      tag="p"
                      variant="displayLG"
                      class="text-base-900 font-display font-light"
                    >
                      {plan.priceStatic}
                    </Text>
                  ) : (
                    <Text tag="p" variant="displayLG" class="text-base-900">
                      <span class="tracking-tighter font-display font-light">
                        {plan.priceMonthly ?? plan.priceAnnual ?? ""}
                      </span>
                      {plan.priceMonthly && (
                        <span class="text-lg ml-1 text-base-700">/{lang === 'en' ? 'month' : 'bulan'}</span>
                      )}
                    </Text>
                  )}
                </div>
                {plan.features && (
                  <ul class="divide-y divide-base-200 mt-4">
                    {plan.features.map((item) => (
                      <li class="flex items-center justify-between py-3 text-base-800">
                        <Text
                          tag="span"
                          variant="textBase"
                          class="text-base-800"
                        >
                          {item.label}
                        </Text>
                        <Text tag="span" variant="textSM" class="text-base-500">
                          {item.value}
                        </Text>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
              <Button
                size="base"
                variant="default"
                isLink={true}
                href="/signin"
                class="w-fit mt-8"
              >
                {t('pricing.choosePlan')}
              </Button>
            </div>
          ))
        }
      </div>
    </Wrapper>
  </section>
  <Faq />
</BaseLayout>
