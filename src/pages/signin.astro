---
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import { getLangFromLocals, useTranslations } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Read error/message from URL params (set by API endpoint)
const errorMsg = Astro.url.searchParams.get('error');
const successMsg = Astro.url.searchParams.get('message');
const redirectTo = Astro.url.searchParams.get('redirect') || '/dashboard';

const lang = getLangFromLocals(Astro.locals);
const t = useTranslations(lang);
---

<BaseLayout hideNav={true} hideFooter={true}>
  <div class="flex h-dvh" data-lang={lang} data-redirect={redirectTo} id="signin-container">
    <div class="w-full max-w-md py-24 lg:py-48 mx-auto">
      <div class="text-center">
        <Text
          tag="h1"
          variant="displayLG"
          class="text-base-900 font-display font-light"
        >
          {t('auth.signinTitle')}
        </Text>
        <Text tag="p" variant="textBase" class="text-base-600 mt-4">
          {lang === 'en' ? 'Welcome back. Enter your email and password to log in.' : 'Selamat datang kembali. Masukkan email dan kata sandi untuk masuk.'}
        </Text>
      </div>

      {/* Success message (e.g. after email verification) */}
      {successMsg && (
        <div class="mt-6 rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800" role="status">
          {successMsg}
        </div>
      )}

      {/* Error message */}
      {errorMsg && (
        <div class="mt-6 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800" role="alert">
          {errorMsg}
        </div>
      )}

      <form method="POST" action="/api/auth/signin" class="mt-10 space-y-4">
        <input type="hidden" name="redirect" value={redirectTo} />
        <div class="w-full">
          <div class="flex items-baseline justify-between mb-1">
            <label for="email" class="text-sm font-medium text-base-500"
              >{t('auth.emailLabel')}</label
            >
          </div>
          <div class="relative z-0 focus-within:z-10">
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder={t('footer.emailPlaceholder')}
              class="block w-full px-4 py-2 text-xs leading-tight align-middle bg-white border border-transparent transition duration-300 ease-in-out focus:z-10 h-9 rounded-md text-base-500 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
              inputmode="email"
              autocomplete="username webauthn"
              autofocus
            />
          </div>
        </div>
        <div class="w-full">
          <div class="flex items-baseline justify-between mb-1">
            <label for="password" class="text-sm font-medium text-base-500"
              >{t('auth.passwordLabel')}</label
            >
          </div>
          <div class="relative z-0 focus-within:z-10">
            <input
              required
              id="password"
              name="password"
              type="password"
              placeholder="••••••••"
              class="block w-full px-4 py-2 text-xs leading-tight align-middle bg-white border border-transparent transition duration-300 ease-in-out focus:z-10 h-9 rounded-md text-base-500 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm"
              aria-required="true"
            />
          </div>
        </div>
        <div class="flex items-center">
          <input
            type="checkbox"
            id="login-remember"
            name="login-remember"
            class="rounded shadow border-base-300 text-accent-600 focus:ring-accent-500 focus:ring-offset-2 focus:ring-2 size-4"
          />
          <label
            for="login-remember"
            class="ml-2 text-sm font-medium text-base-500"
          >
            {lang === 'en' ? 'Remember me for 30 days' : 'Ingat saya selama 30 hari'}
          </label>
        </div>
        <div class="flex flex-col gap-2">
          <Button size="base" variant="accent" type="submit" class="w-full justify-center">
            {t('auth.signinButton')}
          </Button>
          <button
            type="button"
            id="passkey-signin-btn"
            class="w-full inline-flex items-center justify-center px-4 py-2 text-xs font-semibold rounded-md bg-white text-base-800 border border-base-200 hover:bg-base-50 transition duration-200 focus:outline-none focus:ring-2 focus:ring-base-500 h-9 shadow-sm"
          >
            🔑 {lang === 'en' ? 'Sign in with Passkey' : 'Masuk dengan Passkey'}
          </button>
        </div>
      </form>

      <Text
        tag="p"
        variant="textXS"
        class="mt-4 font-medium text-center text-base-500"
      >
        {t('auth.noAccount')}
        <a
          href="/signup"
          class="font-medium text-accent-500 hover:text-base-500 ml-1"
        >
          {t('nav.signup')}
        </a>
      </Text>
    </div>
  </div>
</BaseLayout>

<script>
  import 'webauthn-polyfills';

  let autofillAbortController = new AbortController();

  function getContainerMeta() {
    const container = document.getElementById('signin-container');
    const lang = container?.getAttribute('data-lang') || 'en';
    const redirectTo = container?.getAttribute('data-redirect') || '/dashboard';
    return { lang, redirectTo };
  }

  async function initializeConditionalAutofill() {
    const { redirectTo } = getContainerMeta();
    try {
      const capabilities = await PublicKeyCredential.getClientCapabilities();
      if (capabilities.conditionalGet === true) {
        const optionsRes = await fetch('/api/auth/passkey/login-options');
        if (!optionsRes.ok) return;
        const options = await optionsRes.json();

        const publicKey = PublicKeyCredential.parseRequestOptionsFromJSON(options);
        const credential = await navigator.credentials.get({
          publicKey,
          signal: autofillAbortController.signal,
          mediation: 'conditional',
        });

        if (!credential) return;

        // Send assertion to verify
        const verifyRes = await fetch('/api/auth/passkey/login-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify((credential as any).toJSON()),
        });

        if (verifyRes.ok) {
          window.location.href = redirectTo;
        } else {
          const data = await verifyRes.json();
          alert(data.error || 'Authentication failed');
        }
      }
    } catch (err: any) {
      if (['NotAllowedError', 'AbortError'].includes(err.name)) {
        return;
      }
      console.error('Conditional UI error:', err);
    }
  }

  async function triggerButtonAuthentication() {
    autofillAbortController.abort();
    autofillAbortController = new AbortController();

    const { lang, redirectTo } = getContainerMeta();
    const passkeyBtn = document.getElementById('passkey-signin-btn');
    if (!passkeyBtn) return;
    (passkeyBtn as HTMLButtonElement).disabled = true;
    const originalText = passkeyBtn.textContent;
    passkeyBtn.textContent = lang === 'en' ? 'Checking authenticator...' : 'Memeriksa autentikator...';

    try {
      const optionsRes = await fetch('/api/auth/passkey/login-options');
      if (!optionsRes.ok) {
        const errData = await optionsRes.json();
        throw new Error(errData.error || 'Failed to fetch options');
      }
      const options = await optionsRes.json();

      const publicKey = PublicKeyCredential.parseRequestOptionsFromJSON(options);
      const credential = await navigator.credentials.get({
        publicKey,
        signal: autofillAbortController.signal,
      });

      if (!credential) {
        throw new Error(lang === 'en' ? 'Failed to get credentials' : 'Gagal mendapatkan kredensial');
      }

      passkeyBtn.textContent = lang === 'en' ? 'Verifying...' : 'Memverifikasi...';

      const verifyRes = await fetch('/api/auth/passkey/login-verify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify((credential as any).toJSON()),
      });

      if (!verifyRes.ok) {
        const errData = await verifyRes.json();
        throw new Error(errData.error || 'Verification failed');
      }

      window.location.href = redirectTo;
    } catch (err: any) {
      console.error(err);
      alert(err.message || (lang === 'en' ? 'Sign in failed' : 'Gagal masuk'));
      (passkeyBtn as HTMLButtonElement).disabled = false;
      passkeyBtn.textContent = originalText;
      initializeConditionalAutofill();
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    // 1. Initialize Conditional UI
    initializeConditionalAutofill();

    // 2. Button authentication trigger
    const passkeyBtn = document.getElementById('passkey-signin-btn');
    if (passkeyBtn) {
      passkeyBtn.addEventListener('click', triggerButtonAuthentication);
    }
  });
</script>
