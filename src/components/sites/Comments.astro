---
import { desc, eq } from 'drizzle-orm';
import Button from '@/components/fundations/elements/Button.astro';
import Text from '@/components/fundations/elements/Text.astro';
import EmptyState from '@/components/global/EmptyState.astro';
import { db } from '@/db';
import { comments, profiles } from '@/db/schema';

const { siteId } = Astro.props;
const user = (Astro.locals as any).user;
const profile = (Astro.locals as any).profile;

// Fetch comments using Drizzle
const dbComments = await db
  .select({
    id: comments.id,
    content: comments.content,
    user_id: comments.user_id,
    created_at: comments.created_at,
    profiles: {
      username: profiles.username,
      full_name: profiles.full_name,
      avatar_url: profiles.avatar_url,
      role: profiles.role,
    },
  })
  .from(comments)
  .leftJoin(profiles, eq(comments.user_id, profiles.id))
  .where(eq(comments.site_id, siteId))
  .orderBy(desc(comments.created_at));

const errorMsg = Astro.url.searchParams.get('error');
const successMsg = Astro.url.searchParams.get('message');
---

<div id="comments" class="scroll-mt-24">
  <Text tag="h3" variant="textLG" class="text-base-900 font-semibold mb-6">
    Komentar ({dbComments?.length || 0})
  </Text>

  {/* Form */}
  <div class="mb-10">
    {user ? (
      <form method="POST" action="/api/sites/comment" class="space-y-4 max-w-2xl">
        <input type="hidden" name="site_id" value={siteId} />
        
        {errorMsg && (
          <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-800">
            {errorMsg}
          </div>
        )}
        {successMsg && (
          <div class="rounded-lg bg-green-50 border border-green-200 px-4 py-3 text-sm text-green-800">
            {successMsg}
          </div>
        )}

        <div class="flex gap-4">
          <div class="shrink-0 mt-1">
            {profile?.avatar_url ? (
              <img
                src={profile.avatar_url}
                alt={profile.full_name || 'Avatar'}
                class="size-8 rounded-full object-cover ring-1 ring-base-200"
              />
            ) : (
              <div class="size-8 rounded-full bg-accent-100 text-accent-600 flex items-center justify-center text-xs font-semibold ring-1 ring-base-200">
                {(profile?.username || user.email || 'U').charAt(0).toUpperCase()}
              </div>
            )}
          </div>
          <div class="flex-1 min-w-0">
            <textarea
              name="content"
              required
              rows="3"
              placeholder="Berikan masukan, pertanyaan, atau dukungan untuk kreator..."
              class="block w-full px-4 py-2 text-sm bg-white border border-transparent rounded-lg text-base-700 ring-1 ring-base-200 placeholder-base-400 focus:border-accent-500 focus:ring-accent-100 focus:ring-2 focus:outline-none shadow-sm resize-y"
            ></textarea>
            <div class="mt-2 flex justify-end">
              <Button size="sm" variant="accent" type="submit">
                Kirim Komentar
              </Button>
            </div>
          </div>
        </div>
      </form>
    ) : (
      <div class="rounded-lg border border-base-200 bg-base-50 p-6 text-center max-w-2xl">
        <Text tag="p" variant="textSM" class="text-base-600 mb-4">
          Silakan login untuk memberikan komentar.
        </Text>
        <Button isLink size="sm" variant="accent" href={`/signin?redirect=${encodeURIComponent(Astro.url.pathname)}`} class="inline-flex">
          Sign In
        </Button>
      </div>
    )}
  </div>

  {/* Comments List */}
  <div class="space-y-6 max-w-2xl">
    {(!dbComments || dbComments.length === 0) ? (
      <EmptyState
        title="Belum Ada Komentar"
        description="Belum ada tanggapan atau masukan untuk produk ini. Jadilah orang pertama yang memulai diskusi!"
        icon="ri-chat-smile-line"
        class="max-w-2xl"
      />
    ) : (
      dbComments.map((comment: any) => (
        <div class="flex gap-4">
          <div class="shrink-0 mt-1">
            {comment.profiles?.avatar_url ? (
              <img
                src={comment.profiles.avatar_url}
                alt={comment.profiles.full_name || 'Avatar'}
                class="size-8 rounded-full object-cover ring-1 ring-base-200"
              />
            ) : (
              <div class="size-8 rounded-full bg-accent-100 text-accent-600 flex items-center justify-center text-xs font-semibold ring-1 ring-base-200">
                {(comment.profiles?.username || 'U').charAt(0).toUpperCase()}
              </div>
            )}
          </div>
          <div class="flex-1 min-w-0 bg-base-50 rounded-lg p-4">
            <div class="flex items-center gap-2 mb-1 justify-between">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-base-900">
                  {comment.profiles?.full_name || comment.profiles?.username || 'User'}
                </span>
                {comment.profiles?.role === 'maker' && (
                  <span title="Maker" class="inline-flex items-center justify-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-green-100 text-green-800 border border-green-200 uppercase tracking-wider">
                    Maker
                  </span>
                )}
                {comment.profiles?.role === 'admin' && (
                  <span title="Admin" class="inline-flex items-center justify-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-purple-100 text-purple-800 border border-purple-200 uppercase tracking-wider">
                    Admin
                  </span>
                )}
                <span class="text-xs text-base-400">
                  • {new Date(comment.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' })}
                </span>
              </div>
              {user && comment.user_id !== user.id && (
                <button
                  type="button"
                  data-report-comment-btn={comment.id}
                  class="text-[10px] text-base-400 hover:text-red-500 font-medium cursor-pointer transition-colors"
                >
                  Laporkan
                </button>
              )}
            </div>
            <p class="text-sm text-base-700 whitespace-pre-wrap break-words">
              {comment.content}
            </p>
          </div>
        </div>
      ))
    )}
  </div>
</div>

<script is:inline>
  (() => {
    document.addEventListener('click', async (e) => {
      const btn = e.target.closest('[data-report-comment-btn]');
      if (!btn) return;

      const commentId = btn.dataset.reportCommentBtn;
      if (!commentId) return;

      const reason = prompt('Masukkan alasan pelaporan komentar ini:');
      if (!reason || !reason.trim()) return;

      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Melaporkan...';

      try {
        const res = await fetch('/api/comments/report', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ comment_id: commentId, reason }),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Gagal melaporkan komentar');

        alert('Terima kasih, laporan Anda telah dikirim untuk ditinjau oleh moderator.');
        btn.textContent = 'Dilaporkan';
        btn.classList.add('text-red-500');
      } catch (err) {
        alert(err.message || 'Gagal melaporkan komentar');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });
  })();
</script>
